    "edm_faq": {
      "type": "edm-faq",
      "blocks": {
        "faq_1": {
          "type": "faq_item",
          "settings": {
            "question": "¿Los bronceadores son seguros para piel sensible?",
            "answer": "<p>Sí. Nuestra fórmula está validada por dermatólogos y libre de parabenos, sulfatos y colorantes artificiales. Ideal para pieles reactivas y delicadas.</p>"
          }
        },
        "faq_2": {
          "type": "faq_item",
          "settings": {
            "question": "¿Cuánto tiempo dura el bronceado?",
            "answer": "<p>Con uso regular, el bronceado se mantiene y prolonga por 3 a 5 días. Para mejores resultados, aplica después del baño sobre piel hidratada.</p>"
          }
        },
        "faq_3": {
          "type": "faq_item",
          "settings": {
            "question": "¿Tienen protección solar?",
            "answer": "<p>Nuestros bronceadores no contienen filtro solar. Te recomendamos combinarlos con protector solar para una exposición responsable al sol.</p>"
          }
        },
        "faq_4": {
          "type": "faq_item",
          "settings": {
            "question": "¿Hacen envíos a todo Colombia?",
            "answer": "<p>Sí, enviamos a todo el territorio nacional. Envío gratis en pedidos desde $80.000. El tiempo de entrega es de 2 a 5 días hábiles.</p>"
          }
        }
      },
