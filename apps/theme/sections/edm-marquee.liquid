<div
  class="edm-mq"
  style="--pt:{{ section.settings.padding_top }}px;--pb:{{ section.settings.padding_bottom }}px;padding-top:var(--pt);padding-bottom:var(--pb);"
  aria-label="Compromisos de marca"
>
  <div class="edm-mq__track">
    <div class="edm-mq__inner">
      {%- for block in section.blocks -%}
        <span class="edm-mq__item" {{ block.shopify_attributes }}>
          <span class="edm-mq__star edm-anim-star-spin" aria-hidden="true">
            {%- render 'edm-starfish', stroke: 'rgba(255,255,255,0.6)' -%}
          </span>
          <span class="edm-mq__txt">{{ block.settings.text }}</span>
        </span>
      {%- endfor -%}
      {%- for block in section.blocks -%}
        <span class="edm-mq__item" aria-hidden="true">
          <span class="edm-mq__star edm-anim-star-spin">
            {%- render 'edm-starfish', stroke: 'rgba(255,255,255,0.6)' -%}
          </span>
          <span class="edm-mq__txt">{{ block.settings.text }}</span>
        </span>
      {%- endfor -%}
    </div>
  </div>
</div>

{% stylesheet %}
.edm-mq {
  overflow: hidden;
  background: linear-gradient(135deg, #FFA5D3 0%, #FF88BB 50%, #FF9966 100%);
  border-top: 1px solid rgba(255, 255, 255, 0.18);
  border-bottom: 1px solid rgba(255, 255, 255, 0.18);
}
.edm-mq__track { overflow: hidden; }
.edm-mq__inner {
  display: flex;
  width: max-content;
  animation: edmMqScroll 38s linear infinite;
}
.edm-mq:hover .edm-mq__inner { animation-play-state: paused; }
@keyframes edmMqScroll {
  0%   { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}
.edm-mq__item {
  display: inline-flex;
  align-items: center;
  gap: 2rem;
  padding: 1.7rem 2.6rem;
  white-space: nowrap;
}
.edm-mq__star {
  width: 2rem;
  height: 2rem;
  flex-shrink: 0;
  color: #ffffff;
  display: inline-flex;
  filter: drop-shadow(0 2px 6px rgba(255, 136, 187, 0.4));
}
.edm-mq__star svg { width: 100%; height: 100%; display: block; }
.edm-mq__txt {
  font-family: 'Quicksand', system-ui, sans-serif;
  font-size: 1.25rem;
  letter-spacing: 0.26em;
  text-transform: uppercase;
  font-weight: 600;
  color: #ffffff;
  text-shadow: 0 1px 8px rgba(255, 136, 187, 0.3);
}
{% endstylesheet %}

{% schema %}
{
  "name": "Marquee de marca",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding superior",
      "min": 0, "max": 40, "step": 4, "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding inferior",
      "min": 0, "max": 40, "step": 4, "unit": "px",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "phrase",
      "name": "Frase",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Texto",
          "default": "Bronceado Natural"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Marquee de marca",
      "blocks": [
        { "type": "phrase", "settings": { "text": "Disfruta tus días bajo el sol" } },
        { "type": "phrase", "settings": { "text": "Bronceado es mi lenguaje del amor" } },
        { "type": "phrase", "settings": { "text": "Hecho en Medellín · Colombia" } },
        { "type": "phrase", "settings": { "text": "Always Tan Club" } },
        { "type": "phrase", "settings": { "text": "Reef safe · Cruelty free" } },
        { "type": "phrase", "settings": { "text": "Ingredientes naturales" } }
      ]
    }
  ]
}
{% endschema %}
