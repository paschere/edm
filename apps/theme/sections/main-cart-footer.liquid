{{ 'component-cart.css' | asset_url | stylesheet_tag }}
{{ 'component-totals.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-discounts.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div
  class="gradient color-{{ section.settings.color_scheme }}{% if cart == empty %} is-empty{% endif %}"
  id="main-cart-footer"
  data-id="{{ section.id }}"
>
  <div class="page-width">
    <div class="cart__footer isolate section-{{ section.id }}-padding">
      {%- if settings.show_cart_note -%}
        <cart-note class="cart__note field">
          <label for="Cart-note">{{ 'sections.cart.note' | t }}</label>
          <textarea
            class="text-area field__input"
            name="note"
            form="cart"
            id="Cart-note"
            placeholder="{{ 'sections.cart.note' | t }}"
          >{{ cart.note }}</textarea>
        </cart-note>
      {%- endif -%}

      <div class="cart__blocks">
        {% for block in section.blocks %}
          {%- case block.type -%}
            {%- when '@app' -%}
              {% render block %}
            {%- when 'subtotal' -%}
              {%- assign ship_threshold = 16000000 -%}
              {%- assign ship_remaining = ship_threshold | minus: cart.total_price -%}
              {%- assign ship_pct = cart.total_price | times: 100 | divided_by: ship_threshold | at_most: 100 -%}
              <div class="edm-ship-bar" id="edm-ship-bar">
                <div class="edm-ship-bar__top">
                  <svg class="edm-ship-bar__truck" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                  {%- if ship_remaining > 0 -%}
                    <p class="edm-ship-bar__msg">
                      Te faltan <strong>{{ ship_remaining | money_without_trailing_zeros }}</strong> para <strong>envío gratis</strong>
                    </p>
                  {%- else -%}
                    <p class="edm-ship-bar__msg edm-ship-bar__msg--done">
                      ¡Tienes envío gratis!
                    </p>
                  {%- endif -%}
                </div>
                <div class="edm-ship-bar__track" role="progressbar" aria-valuenow="{{ ship_pct }}" aria-valuemin="0" aria-valuemax="100" aria-label="Progreso hacia envío gratis">
                  <div class="edm-ship-bar__fill" style="width:{{ ship_pct }}%"></div>
                </div>
              </div>

              <div class="js-contents" {{ block.shopify_attributes }}>
                <div>
                  {%- if cart.cart_level_discount_applications.size > 0 -%}
                    <ul class="discounts list-unstyled" role="list" aria-label="{{ 'customer.order.discount' | t }}">
                      {%- for discount in cart.cart_level_discount_applications -%}
                        <li class="discounts__discount discounts__discount--position">
                          {{- 'icon-discount.svg' | inline_asset_content -}}
                          {{ discount.title | escape }}
                          (-{{ discount.total_allocated_amount | money }})
                        </li>
                      {%- endfor -%}
                    </ul>
                  {%- endif -%}
                </div>

                <div class="totals">
                  <h2 class="totals__total">{{ 'sections.cart.estimated_total' | t }}</h2>
                  <p class="totals__total-value">{{ cart.total_price | money_with_currency }}</p>
                </div>

                <small class="tax-note caption-large rte">
                  {%- if cart.duties_included and cart.taxes_included -%}
                    {%- if shop.shipping_policy.body == blank -%}
                      {{ 'sections.cart.duties_and_taxes_included_shipping_at_checkout_without_policy' | t }}
                    {%- else -%}
                      {{
                        'sections.cart.duties_and_taxes_included_shipping_at_checkout_with_policy_html'
                        | t: link: shop.shipping_policy.url
                      }}
                    {%- endif -%}
                  {%- elsif cart.duties_included == false and cart.taxes_included -%}
                    {%- if shop.shipping_policy.body == blank -%}
                      {{ 'sections.cart.taxes_included_shipping_at_checkout_without_policy' | t }}
                    {%- else -%}
                      {{
                        'sections.cart.taxes_included_shipping_at_checkout_with_policy_html'
                        | t: link: shop.shipping_policy.url
                      }}
                    {%- endif -%}
                  {%- elsif cart.duties_included and cart.taxes_included == false -%}
                    {%- if shop.shipping_policy.body == blank -%}
                      {{ 'sections.cart.duties_included_taxes_at_checkout_shipping_at_checkout_without_policy' | t }}
                    {%- else -%}
                      {{
                        'sections.cart.duties_included_taxes_at_checkout_shipping_at_checkout_with_policy_html'
                        | t: link: shop.shipping_policy.url
                      }}
                    {%- endif -%}
                  {%- elsif cart.duties_included == false and cart.taxes_included == false -%}
                    {%- if shop.shipping_policy.body == blank -%}
                      {{ 'sections.cart.taxes_at_checkout_shipping_at_checkout_without_policy' | t }}
                    {%- else -%}
                      {{
                        'sections.cart.taxes_at_checkout_shipping_at_checkout_with_policy_html'
                        | t: link: shop.shipping_policy.url
                      }}
                    {%- endif -%}
                  {%- endif -%}
                </small>
              </div>
            {%- else -%}
              <div class="edm-cart-cedula" {{ block.shopify_attributes }}>
                <label class="edm-cart-cedula__label" for="edm-cedula-input">Cédula / NIT <span class="edm-cart-cedula__req" aria-hidden="true">*</span></label>
                <input
                  type="text"
                  id="edm-cedula-input"
                  name="attributes[Cedula NIT]"
                  form="cart"
                  class="edm-cart-cedula__input"
                  placeholder="Ej. 1234567890 o 900123456-1"
                  value="{{ cart.attributes['Cedula NIT'] }}"
                  autocomplete="off"
                  inputmode="numeric"
                >
                <p class="edm-cart-cedula__hint">Requerido para factura electrónica</p>
              </div>

              <div class="cart__ctas">
                <button
                  type="submit"
                  id="checkout"
                  class="cart__checkout-button button"
                  name="checkout"
                  {% if cart == empty %}
                    disabled
                  {% endif %}
                  form="cart"
                >
                  {{ 'sections.cart.checkout' | t }}
                </button>
              </div>

              {%- if additional_checkout_buttons -%}
                <div class="cart__dynamic-checkout-buttons additional-checkout-buttons">
                  {{ content_for_additional_checkout_buttons }}
                </div>
              {%- endif -%}
          {%- endcase -%}
        {% endfor %}

        <div id="cart-errors"></div>
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  var THRESHOLD = 16000000;
  function updateShipBar(totalCents) {
    var bar = document.getElementById('edm-ship-bar');
    if (!bar) return;
    var remaining = THRESHOLD - totalCents;
    var pct = Math.min(100, Math.round((totalCents / THRESHOLD) * 100));
    var fill = bar.querySelector('.edm-ship-bar__fill');
    var msg = bar.querySelector('.edm-ship-bar__msg');
    if (fill) fill.style.width = pct + '%';
    if (msg) {
      if (remaining > 0) {
        var formatted = '$ ' + Math.round(remaining / 100).toLocaleString('es-CO');
        msg.innerHTML = 'Te faltan <strong>' + formatted + '</strong> para <strong>envío gratis</strong>';
        msg.classList.remove('edm-ship-bar__msg--done');
      } else {
        msg.innerHTML = '¡Tienes envío gratis!';
        msg.classList.add('edm-ship-bar__msg--done');
      }
    }
    var track = bar.querySelector('.edm-ship-bar__track');
    if (track) track.setAttribute('aria-valuenow', pct);
  }

  if (typeof window.subscribe === 'function' && window.PUB_SUB_EVENTS) {
    window.subscribe(window.PUB_SUB_EVENTS.cartUpdate, function() {
      fetch('/cart.js').then(function(r) { return r.json(); }).then(function(cart) {
        updateShipBar(cart.total_price);
      });
    });
  }

  var input = document.getElementById('edm-cedula-input');
  if (input) {
    var timer;
    input.addEventListener('input', function() {
      clearTimeout(timer);
      var val = input.value;
      if (val.trim()) input.closest('.edm-cart-cedula').classList.remove('edm-cart-cedula--error');
      timer = setTimeout(function() {
        fetch('/cart/update.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ attributes: { 'Cedula NIT': val } })
        });
      }, 600);
    });
  }

  var cartForm = document.getElementById('cart');
  if (cartForm) {
    cartForm.addEventListener('submit', function(e) {
      if (!e.submitter || e.submitter.name !== 'checkout') return;
      var inp = document.getElementById('edm-cedula-input');
      if (!inp || inp.value.trim() !== '') return;
      e.preventDefault();
      inp.closest('.edm-cart-cedula').classList.add('edm-cart-cedula--error');
      inp.focus();
    });
  }
})();
</script>

{% stylesheet %}
.edm-ship-bar {
  background: rgba(208,177,106,0.08);
  border: 1px solid rgba(208,177,106,0.3);
  border-radius: 8px;
  padding: 1.6rem 2rem 1.8rem;
  margin-bottom: 2.4rem;
}
.edm-ship-bar__top {
  display: flex;
  align-items: center;
  gap: 1.2rem;
  margin-bottom: 1.2rem;
}
.edm-ship-bar__truck {
  width: 2rem;
  height: 2rem;
  flex-shrink: 0;
  stroke: #FF88BB;
}
.edm-ship-bar__msg {
  font-size: 1.4rem;
  color: rgba(var(--color-foreground), 0.8);
  margin: 0;
  line-height: 1.4;
}
.edm-ship-bar__msg strong { color: #FF88BB; font-weight: 700; }
.edm-ship-bar__msg--done {
  color: #1a6b34;
  font-weight: 600;
}
.edm-ship-bar__msg--done + .edm-ship-bar__track .edm-ship-bar__fill {
  background: #1a6b34;
}
.edm-ship-bar__track {
  height: 5px;
  background: rgba(var(--color-foreground), 0.1);
  border-radius: 40px;
  overflow: hidden;
}
.edm-ship-bar__fill {
  height: 100%;
  background: linear-gradient(90deg, #FFCC99 0%, #FF88BB 100%);
  border-radius: 40px;
  transition: width 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  min-width: 4px;
}

.edm-cart-cedula {
  margin-bottom: 1.6rem;
}
.edm-cart-cedula__label {
  display: block;
  font-size: 1.3rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: rgba(var(--color-foreground), 0.75);
  margin-bottom: 0.8rem;
}
.edm-cart-cedula__req { color: #c0392b; }
.edm-cart-cedula__input {
  display: block;
  width: 100%;
  padding: 1.2rem 1.6rem;
  border: 1.5px solid rgba(var(--color-foreground), 0.2);
  border-radius: var(--inputs-radius, 4px);
  background: transparent;
  color: rgb(var(--color-foreground));
  font-size: 1.5rem;
  line-height: 1;
  transition: border-color 0.2s ease;
  box-sizing: border-box;
}
.edm-cart-cedula__input:focus {
  outline: none;
  border-color: rgba(var(--color-foreground), 0.6);
}
.edm-cart-cedula__hint {
  font-size: 1.2rem;
  color: rgba(var(--color-foreground), 0.5);
  margin: 0.6rem 0 0;
}
.edm-cart-cedula--error .edm-cart-cedula__input { border-color: #c0392b; }
.edm-cart-cedula--error .edm-cart-cedula__hint {
  color: #c0392b;
  font-weight: 600;
}
.edm-cart-cedula--error .edm-cart-cedula__hint::before { content: '⚠ '; }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.main-cart-footer.name",
  "class": "cart__footer-wrapper",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },    
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "subtotal",
      "name": "t:sections.main-cart-footer.blocks.subtotal.name",
      "limit": 1
    },
    {
      "type": "buttons",
      "name": "t:sections.main-cart-footer.blocks.buttons.name",
      "limit": 1
    },
    {
      "type": "@app"
    }
  ]
}
{% endschema %}
