{%- liquid
  assign img_left = false
  if section.settings.image_position == 'left'
    assign img_left = true
  endif
-%}

<section
  class="edm-fs color-{{ section.settings.color_scheme }} gradient"
  style="--pt:{{ section.settings.padding_top }}px;--pb:{{ section.settings.padding_bottom }}px;padding-top:var(--pt);padding-bottom:var(--pb);position:relative;overflow:hidden;"
  aria-label="{{ section.settings.title | default: 'Nuestra historia' | escape }}"
>
  {%- render 'edm-brand-decor', variant: 'corners', tone: 'soft', opacity: '0.3' -%}

  <div class="edm-fs__inner page-width{% if img_left %} edm-fs__inner--img-left{% endif %}" style="position:relative;z-index:1;">

    <div class="edm-fs__media">
      {%- if section.settings.founder_image != blank -%}
        <div class="edm-fs__img-wrap">
          {{
            section.settings.founder_image
            | image_url: width: 900
            | image_tag:
              loading: 'lazy',
              width: 900,
              class: 'edm-fs__img',
              alt: section.settings.image_alt | default: 'Fundadora de Estrella de Mar'
          }}
          {%- if section.settings.image_badge != blank -%}
            <div class="edm-fs__badge" aria-hidden="true">{{ section.settings.image_badge }}</div>
          {%- endif -%}
        </div>
      {%- else -%}
        <div class="edm-fs__placeholder" aria-hidden="true">
          <span>Estrella de Mar</span>
        </div>
      {%- endif -%}
    </div>

    <div class="edm-fs__copy">
      {%- if section.settings.eyebrow != blank -%}
        <p class="edm-fs__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      <h2 class="edm-fs__h2">
        {{ section.settings.title | default: 'Creada con propósito, hecha en' }}
        {%- if section.settings.title_script != blank -%}
          <span class="edm-script edm-fs__h2-script">{{ section.settings.title_script }}</span>
        {%- endif -%}
      </h2>

      {%- if section.settings.body_text != blank -%}
        <div class="edm-fs__body">{{ section.settings.body_text }}</div>
      {%- endif -%}

      {%- assign stat_blocks = section.blocks | where: 'type', 'stat' -%}
      {%- if stat_blocks.size > 0 -%}
        <div class="edm-fs__stats">
          {%- for block in stat_blocks -%}
            <div class="edm-fs__stat" {{ block.shopify_attributes }}>
              <span class="edm-fs__stat-val">{{ block.settings.number }}</span>
              <span class="edm-fs__stat-lbl">{{ block.settings.label }}</span>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- if section.settings.cta_label != blank -%}
        <a href="{{ section.settings.cta_url | default: '/pages/nuestra-historia' }}" class="edm-fs__btn">
          {{ section.settings.cta_label }}
          <span class="edm-fs__btn-arrow" aria-hidden="true">→</span>
        </a>
      {%- endif -%}
    </div>

  </div>
</section>

{% stylesheet %}
.edm-fs { overflow: hidden; }

.edm-fs__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8rem;
  align-items: center;
}
.edm-fs__inner--img-left .edm-fs__media { order: 1; }
.edm-fs__inner--img-left .edm-fs__copy  { order: 2; }
.edm-fs__inner:not(.edm-fs__inner--img-left) .edm-fs__media { order: 2; }
.edm-fs__inner:not(.edm-fs__inner--img-left) .edm-fs__copy  { order: 1; }

.edm-fs__img-wrap {
  position: relative;
  display: block;
}
.edm-fs__img {
  width: 100%;
  border-radius: 4px;
  display: block;
  object-fit: cover;
  aspect-ratio: 4/5;
}

.edm-fs__badge {
  position: absolute;
  bottom: -2.4rem;
  right: -2.4rem;
  width: 11rem; height: 11rem;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF88BB 0%, #FF9966 100%);
  display: flex; align-items: center; justify-content: center;
  text-align: center;
  padding: 1.6rem;
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.4rem;
  font-style: italic;
  font-weight: 500;
  line-height: 1.25;
  color: #fff;
  box-shadow: 0 12px 32px -8px rgba(255, 136, 187, 0.55);
  animation: edmFsBadgeFloat 7s ease-in-out infinite;
}
@keyframes edmFsBadgeFloat {
  0%, 100% { transform: translateY(0) rotate(-3deg); }
  50%       { transform: translateY(-6px) rotate(3deg); }
}

.edm-fs__placeholder {
  aspect-ratio: 4/5;
  border-radius: 1.6rem;
  background: linear-gradient(145deg, #FFA5D3 0%, #FF9966 50%, #FFCC99 100%);
  display: flex; align-items: center; justify-content: center;
}

.edm-fs__h2-script {
  display: inline-block;
  margin-left: 0.18em;
  transform: translateY(0.12em);
  font-size: 1.18em;
  background: linear-gradient(100deg, #FF88BB 0%, #FF9966 50%, #FFCC99 100%);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  color: transparent;
}
.edm-fs__placeholder span {
  font-family: 'Cormorant Garamond', serif;
  font-size: 2rem;
  font-style: italic;
  letter-spacing: 0.15em;
  color: rgba(251, 248, 241, 0.5);
}

.edm-fs__eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 1rem;
  font-size: 1.2rem;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  font-weight: 600;
  color: #FF88BB;
  margin: 0 0 2.8rem;
}
.edm-fs__eyebrow::before {
  content: '';
  width: 28px;
  height: 1px;
  background: currentColor;
  flex-shrink: 0;
}

.edm-fs__h2 {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: clamp(3.8rem, 4vw, 6rem);
  font-weight: 400;
  line-height: 1.1;
  letter-spacing: -0.01em;
  color: #3D2330;
  margin: 0 0 3.2rem;
}

.edm-fs__body {
  font-size: 1.65rem;
  color: #7C5862;
  line-height: 1.78;
  margin: 0 0 3.6rem;
}
.edm-fs__body p { margin: 0 0 1.6rem; }
.edm-fs__body p:last-child { margin: 0; }

.edm-fs__stats {
  display: flex;
  gap: 4rem;
  flex-wrap: wrap;
  padding: 3.2rem 0;
  border-top: 1px solid rgba(11, 8, 5, 0.1);
  border-bottom: 1px solid rgba(11, 8, 5, 0.1);
  margin-bottom: 3.6rem;
}
.edm-fs__stat { display: flex; flex-direction: column; gap: 0.5rem; }
.edm-fs__stat-val {
  font-family: 'Cormorant Garamond', serif;
  font-size: 4rem;
  font-weight: 500;
  font-style: italic;
  color: #3D2330;
  line-height: 1;
}
.edm-fs__stat-lbl {
  font-size: 1.2rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: #A88891;
  font-weight: 500;
}

.edm-fs__btn {
  display: inline-flex;
  align-items: center;
  gap: 1rem;
  font-size: 1.3rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  font-weight: 700;
  color: #3D2330;
  text-decoration: none;
  padding-bottom: 0.4rem;
  border-bottom: 1.5px solid #3D2330;
  transition: all 0.3s ease;
}
.edm-fs__btn:hover { color: #FF88BB; border-color: #FF88BB; gap: 1.6rem; }
.edm-fs__btn-arrow { transition: transform 0.3s ease; }
.edm-fs__btn:hover .edm-fs__btn-arrow { transform: translateX(4px); }

@media (max-width: 989px) {
  .edm-fs__inner { grid-template-columns: 1fr; gap: 4rem; }
  .edm-fs__inner--img-left .edm-fs__media,
  .edm-fs__inner:not(.edm-fs__inner--img-left) .edm-fs__media { order: 1; }
  .edm-fs__inner--img-left .edm-fs__copy,
  .edm-fs__inner:not(.edm-fs__inner--img-left) .edm-fs__copy { order: 2; }
  .edm-fs__badge { right: 0; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Historia de la marca",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "founder_image",
      "label": "Foto (fundadora / producto / lifestyle)"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Texto alternativo",
      "default": "Juliana, fundadora de Estrella de Mar"
    },
    {
      "type": "text",
      "id": "image_badge",
      "label": "Badge circular sobre imagen",
      "default": "Hecho con amor"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Posición imagen",
      "options": [
        { "value": "left",  "label": "Izquierda" },
        { "value": "right", "label": "Derecha" }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Kicker",
      "default": "Nuestra historia"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Creada con propósito, hecha en"
    },
    {
      "type": "text",
      "id": "title_script",
      "label": "Palabra final (script)",
      "default": "Colombia"
    },
    {
      "type": "richtext",
      "id": "body_text",
      "label": "Texto",
      "default": "<p>Estrella de Mar nació en Medellín, de las manos de Juliana — formuladora y apasionada del sol colombiano. Frustrada por bronceadores que maltrataban la piel, decidió crear los suyos: formulados con ingredientes naturales, certificados por el INVIMA y aprobados por dermatólogos.</p><p>Hoy, miles de colombianas los usan para brillar con confianza bajo el sol de su tierra.</p>"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Botón",
      "default": "Conoce nuestra historia"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Destino botón"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Esquema de color",
      "options": [
        { "value": "scheme-1", "label": "Bone" },
        { "value": "scheme-2", "label": "Arena" },
        { "value": "scheme-3", "label": "Oscuro" }
      ],
      "default": "scheme-2"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding superior",
      "min": 0, "max": 120, "step": 4, "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding inferior",
      "min": 0, "max": 120, "step": 4, "unit": "px",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Dato clave",
      "limit": 3,
      "settings": [
        { "type": "text", "id": "number", "label": "Cifra", "default": "10K+" },
        { "type": "text", "id": "label", "label": "Etiqueta", "default": "clientas felices" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Historia de la marca",
      "blocks": [
        { "type": "stat", "settings": { "number": "10K+", "label": "clientas felices" } },
        { "type": "stat", "settings": { "number": "100%", "label": "hecho en Colombia" } },
        { "type": "stat", "settings": { "number": "4.9★", "label": "calificación promedio" } }
      ]
    }
  ]
}
{% endschema %}
