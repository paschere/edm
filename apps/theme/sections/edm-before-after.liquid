<section
  class="edm-ba color-{{ section.settings.color_scheme }} gradient"
  style="--pt:{{ section.settings.padding_top }}px;--pb:{{ section.settings.padding_bottom }}px;padding-top:var(--pt);padding-bottom:var(--pb);"
>
  <div class="edm-ba__head page-width">
    {%- if section.settings.eyebrow != blank -%}
      <p class="edm-ba__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    <div class="edm-ba__head-row">
      <h2 class="edm-ba__h2">{{ section.settings.title | default: 'Resultados que hablan solos' }}</h2>
      <div class="edm-ba__arrows" aria-label="Navegación carrusel">
        <button type="button" class="edm-ba__arrow" id="edm-ba-prev-{{ section.id }}" aria-label="Anterior">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
        <button type="button" class="edm-ba__arrow" id="edm-ba-next-{{ section.id }}" aria-label="Siguiente">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
        </button>
      </div>
    </div>
  </div>

  <div class="edm-ba__viewport">
    <div class="edm-ba__track" id="edm-ba-track-{{ section.id }}" role="list">
      {%- for block in section.blocks -%}
        {%- if block.type == 'slide' -%}
          {%- assign rating = block.settings.rating | default: 5 -%}
          <article class="edm-ba__card" role="listitem" {{ block.shopify_attributes }}>

            <div class="edm-ba__media">
              {%- if block.settings.photo != blank -%}
                {{ block.settings.photo | image_url: width: 800 | image_tag: loading: 'lazy', class: 'edm-ba__photo', alt: block.settings.client_name | escape }}
              {%- else -%}
                <div class="edm-ba__media-fallback" aria-hidden="true">
                  <svg class="edm-ba__media-sun" viewBox="0 0 80 80" fill="none" aria-hidden="true">
                    <circle cx="40" cy="40" r="16" fill="rgba(208,177,106,.35)"/>
                    {%- for i in (1..8) -%}
                      <line
                        x1="40" y1="8"
                        x2="40" y2="18"
                        stroke="rgba(208,177,106,.25)"
                        stroke-width="2"
                        stroke-linecap="round"
                        transform="rotate({{ forloop.index0 | times: 45 }} 40 40)"
                      />
                    {%- endfor -%}
                  </svg>
                </div>
              {%- endif -%}
              <div class="edm-ba__media-overlay" aria-hidden="true"></div>
            </div>

            <div class="edm-ba__body">
              <div class="edm-ba__stars" aria-label="{{ rating }} de 5 estrellas">
                {%- for i in (1..5) -%}
                  {%- if i <= rating -%}
                    <svg class="edm-ba__star edm-ba__star--on" viewBox="0 0 20 20" aria-hidden="true"><path d="M10 1l2.39 7.26H20l-6.19 4.5 2.36 7.26L10 15.5l-6.17 4.52 2.36-7.26L0 8.26h7.61L10 1z" fill="currentColor"/></svg>
                  {%- else -%}
                    <svg class="edm-ba__star edm-ba__star--off" viewBox="0 0 20 20" aria-hidden="true"><path d="M10 1l2.39 7.26H20l-6.19 4.5 2.36 7.26L10 15.5l-6.17 4.52 2.36-7.26L0 8.26h7.61L10 1z" fill="none" stroke="currentColor" stroke-width="1.5"/></svg>
                  {%- endif -%}
                {%- endfor -%}
              </div>

              <blockquote class="edm-ba__quote">
                <span class="edm-ba__deco" aria-hidden="true">"</span>
                <p class="edm-ba__text">{{ block.settings.result_text }}</p>
              </blockquote>

              <footer class="edm-ba__foot">
                <div class="edm-ba__author">
                  {%- assign initials = block.settings.client_name | split: ' ' -%}
                  <div class="edm-ba__avatar" aria-hidden="true">
                    {{- initials[0] | slice: 0, 1 | upcase -}}{{- initials[1] | slice: 0, 1 | upcase -}}
                  </div>
                  <div class="edm-ba__author-info">
                    <span class="edm-ba__name">{{ block.settings.client_name }}</span>
                    {%- if block.settings.product_used != blank -%}
                      <span class="edm-ba__product">{{ block.settings.product_used }}</span>
                    {%- endif -%}
                  </div>
                </div>
              </footer>
            </div>

          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  {%- assign slide_count = section.blocks | where: 'type', 'slide' | size -%}
  {%- if slide_count > 1 -%}
    <div class="edm-ba__dots page-width" role="list" aria-label="Testimonios">
      {%- for i in (1..slide_count) -%}
        <button
          type="button"
          class="edm-ba__dot{% if forloop.first %} is-active{% endif %}"
          id="edm-ba-dot-{{ section.id }}-{{ forloop.index0 }}"
          aria-label="Testimonio {{ forloop.index }}"
        ></button>
      {%- endfor -%}
    </div>
  {%- endif -%}
</section>

<script>
(function() {
  var sid = '{{ section.id }}';
  var track = document.getElementById('edm-ba-track-' + sid);
  if (!track) return;
  var prevBtn = document.getElementById('edm-ba-prev-' + sid);
  var nextBtn = document.getElementById('edm-ba-next-' + sid);

  function cardWidth() {
    var card = track.querySelector('.edm-ba__card');
    if (!card) return 560;
    var gap = parseFloat(window.getComputedStyle(track).columnGap) || 32;
    return card.offsetWidth + gap;
  }

  function syncDots() {
    var idx = Math.round(track.scrollLeft / cardWidth());
    document.querySelectorAll('[id^="edm-ba-dot-' + sid + '-"]').forEach(function(dot, i) {
      dot.classList.toggle('is-active', i === idx);
    });
  }

  if (prevBtn) prevBtn.addEventListener('click', function() { track.scrollBy({ left: -cardWidth(), behavior: 'smooth' }); });
  if (nextBtn) nextBtn.addEventListener('click', function() { track.scrollBy({ left: cardWidth(), behavior: 'smooth' }); });
  document.querySelectorAll('[id^="edm-ba-dot-' + sid + '-"]').forEach(function(dot, i) {
    dot.addEventListener('click', function() { track.scrollTo({ left: i * cardWidth(), behavior: 'smooth' }); });
  });
  track.addEventListener('scroll', syncDots, { passive: true });
})();
</script>

{% stylesheet %}
.edm-ba { overflow: hidden; }

.edm-ba__head {
  display: flex;
  flex-direction: column;
  margin-bottom: 4.8rem;
}
.edm-ba__eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 1rem;
  font-size: 1.2rem;
  letter-spacing: 0.32em;
  text-transform: uppercase;
  font-weight: 600;
  color: #9d7f32;
  margin: 0 0 2rem;
}
.edm-ba__eyebrow::before {
  content: '';
  width: 28px; height: 1px;
  background: currentColor;
  flex-shrink: 0;
}
.edm-ba__head-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 2rem;
}
.edm-ba__h2 {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: clamp(4rem, 4.5vw, 6.4rem);
  font-weight: 400;
  line-height: 1.08;
  color: #0b0805;
  margin: 0;
}

.edm-ba__arrows { display: flex; gap: 0.8rem; flex-shrink: 0; }
.edm-ba__arrow {
  width: 5.2rem; height: 5.2rem;
  border-radius: 50%;
  border: 1.5px solid rgba(11,8,5,.14);
  background: transparent;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  color: #0b0805;
  transition: background .25s ease, border-color .25s ease, color .25s ease;
}
.edm-ba__arrow svg { width: 2.2rem; height: 2.2rem; }
.edm-ba__arrow:hover {
  background: #0b0805;
  border-color: #0b0805;
  color: #fbf8f1;
}

.edm-ba__viewport {
  overflow: hidden;
}
.edm-ba__track {
  display: flex;
  gap: 3.2rem;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  scroll-behavior: smooth;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  padding: 0.4rem max(1.6rem, calc((100vw - 1200px) / 2 + 1.6rem)) 2.4rem;
}
.edm-ba__track::-webkit-scrollbar { display: none; }

.edm-ba__card {
  flex: 0 0 clamp(320px, calc(50% - 1.6rem), 560px);
  scroll-snap-align: start;
  background: #fbf8f1;
  border-radius: 8px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  box-shadow: 0 2px 16px -4px rgba(11,8,5,.08);
  transition: box-shadow .35s ease, transform .35s ease;
}
.edm-ba__card:hover {
  box-shadow: 0 16px 56px -16px rgba(11,8,5,.18);
  transform: translateY(-3px);
}

/* Media zone */
.edm-ba__media {
  position: relative;
  aspect-ratio: 4/3;
  overflow: hidden;
  flex-shrink: 0;
}
.edm-ba__photo {
  width: 100%; height: 100%;
  object-fit: cover;
  display: block;
  transition: transform .6s ease;
}
.edm-ba__card:hover .edm-ba__photo { transform: scale(1.04); }
.edm-ba__media-fallback {
  width: 100%; height: 100%;
  background: linear-gradient(135deg, #e8d9b8 0%, #d4aa6a 40%, #b8882a 75%, #8a6018 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}
.edm-ba__media-sun { width: 80px; height: 80px; }
.edm-ba__media-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, transparent 50%, rgba(11,8,5,.18) 100%);
  pointer-events: none;
}

/* Body */
.edm-ba__body {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 3.6rem 3.6rem 3.2rem;
  gap: 2.4rem;
}

.edm-ba__stars { display: flex; gap: 0.4rem; }
.edm-ba__star { width: 1.8rem; height: 1.8rem; }
.edm-ba__star--on { color: #d0b16a; }
.edm-ba__star--off { color: rgba(208,177,106,.28); }

.edm-ba__quote {
  flex: 1;
  margin: 0;
  position: relative;
}
.edm-ba__deco {
  position: absolute;
  top: -1.6rem;
  left: -0.8rem;
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: 13rem;
  line-height: 1;
  color: rgba(208,177,106,.12);
  pointer-events: none;
  user-select: none;
  z-index: 0;
}
.edm-ba__text {
  position: relative;
  z-index: 1;
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: 2.2rem;
  font-style: italic;
  line-height: 1.6;
  color: #0b0805;
  margin: 0;
}

/* Footer */
.edm-ba__foot {
  margin-top: auto;
  padding-top: 2.4rem;
  border-top: 1px solid rgba(11,8,5,.07);
}
.edm-ba__author {
  display: flex;
  align-items: center;
  gap: 1.4rem;
}
.edm-ba__avatar {
  width: 4.4rem; height: 4.4rem;
  border-radius: 50%;
  background: linear-gradient(135deg, #d0b16a, #9d7f32);
  display: flex; align-items: center; justify-content: center;
  font-size: 1.35rem;
  font-weight: 700;
  color: #fbf8f1;
  flex-shrink: 0;
  letter-spacing: 0.03em;
}
.edm-ba__author-info {
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
}
.edm-ba__name {
  font-size: 1.45rem;
  font-weight: 700;
  color: #0b0805;
  line-height: 1.2;
}
.edm-ba__product {
  font-size: 1.15rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #9d7f32;
  font-weight: 600;
}

/* Dots */
.edm-ba__dots {
  display: flex;
  justify-content: center;
  gap: 0.8rem;
  margin-top: 3.6rem;
}
.edm-ba__dot {
  width: 0.8rem; height: 0.8rem;
  border-radius: 50%;
  border: none;
  background: rgba(11,8,5,.14);
  cursor: pointer;
  padding: 0;
  transition: all .25s ease;
}
.edm-ba__dot.is-active {
  background: #9d7f32;
  width: 2.8rem;
  border-radius: 4px;
}

@media (max-width: 989px) {
  .edm-ba__arrows { display: none; }
  .edm-ba__head { margin-bottom: 3.2rem; }
  .edm-ba__card {
    flex: 0 0 min(84vw, 420px);
  }
  .edm-ba__body { padding: 2.8rem 2.8rem 2.4rem; }
  .edm-ba__text { font-size: 2rem; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Clientas reales",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Kicker", "default": "Clientas reales" },
    { "type": "text", "id": "title", "label": "Título", "default": "Resultados que hablan solos" },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Esquema de color",
      "options": [
        { "value": "scheme-1", "label": "Bone" },
        { "value": "scheme-2", "label": "Arena" }
      ],
      "default": "scheme-2"
    },
    { "type": "range", "id": "padding_top", "label": "Padding superior", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 60 },
    { "type": "range", "id": "padding_bottom", "label": "Padding inferior", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 60 }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Testimonio",
      "settings": [
        { "type": "image_picker", "id": "photo", "label": "Foto (lifestyle / selfie de la clienta)" },
        { "type": "text", "id": "client_name", "label": "Nombre y ciudad", "default": "Valentina, Medellín" },
        { "type": "textarea", "id": "result_text", "label": "Testimonio", "default": "El mejor bronceador que he usado. Mi piel quedó perfecta y el bronceado duró 3 semanas." },
        { "type": "text", "id": "product_used", "label": "Producto usado", "default": "Bronceador Zanahoria" },
        { "type": "range", "id": "rating", "label": "Calificación", "min": 1, "max": 5, "step": 1, "default": 5 }
      ]
    }
  ],
  "presets": [
    {
      "name": "Clientas reales",
      "blocks": [
        { "type": "slide", "settings": { "client_name": "Valentina R., Medellín", "result_text": "El mejor bronceador que he usado en mi vida. Mi piel quedó perfecta para el matrimonio de mi amiga y duró 3 semanas.", "product_used": "Bronceador Zanahoria", "rating": 5 } },
        { "type": "slide", "settings": { "client_name": "Laura M., Bogotá", "result_text": "Me lo recomendó mi dermatólogo y no lo cambio por nada. Ingredientes naturales y no me da alergia.", "product_used": "Bronceador Zanahoria", "rating": 5 } },
        { "type": "slide", "settings": { "client_name": "Daniela P., Cali", "result_text": "El Kit Summer Box es lo mejor. Me lo llevo a cada viaje. Huele increíble y el bronceado es super natural.", "product_used": "Summer Box", "rating": 5 } },
        { "type": "slide", "settings": { "client_name": "Camila R., Eje Cafetero", "result_text": "Increíble para el día de piscina. No me quema y el bronceado dura toda la semana.", "product_used": "Termoprotector", "rating": 5 } }
      ]
    }
  ]
}
{% endschema %}
