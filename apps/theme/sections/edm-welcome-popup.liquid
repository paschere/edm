{%- unless customer -%}
<div
  x-data="edmWelcomePopup({{ section.settings.cooldown_days }})"
  x-init="init()"
  style="display:contents"
>

  <div
    x-show="open"
    x-cloak
    class="edm-pop-scrim"
    x-transition:enter="edm-pop-scrim--trans"
    x-transition:enter-start="edm-pop-scrim--off"
    x-transition:enter-end="edm-pop-scrim--on"
    x-transition:leave="edm-pop-scrim--trans"
    x-transition:leave-start="edm-pop-scrim--on"
    x-transition:leave-end="edm-pop-scrim--off"
    @click.self="dismiss()"
    @keydown.escape.window="dismiss()"
  >

    <div
      class="edm-pop"
      role="dialog"
      aria-modal="true"
      aria-label="{{ section.settings.title | default: 'Bienvenida a Estrella de Mar' | escape }}"
    >

      <div class="edm-pop__visual">
        {%- if section.settings.popup_image != blank -%}
          {{-
            section.settings.popup_image
            | image_url: width: 900
            | image_tag:
              class: 'edm-pop__img',
              loading: 'eager',
              width: 900,
              alt: ''
          -}}
        {%- else -%}
          <div class="edm-pop__img-ph"></div>
        {%- endif -%}
        <div class="edm-pop__visual-overlay" aria-hidden="true">
          {%- if section.settings.image_tagline != blank -%}
            <p class="edm-pop__visual-quote">{{ section.settings.image_tagline }}</p>
          {%- endif -%}
          <p class="edm-pop__visual-brand">Estrella de Mar</p>
        </div>
      </div>

      <div class="edm-pop__body">

        <button
          type="button"
          class="edm-pop__close"
          @click="dismiss()"
          aria-label="Cerrar"
        >
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <path d="M1 1l10 10M11 1L1 11" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
          </svg>
        </button>

        <div x-show="!success">
          {%- if section.settings.eyebrow != blank -%}
            <p class="edm-pop__eyebrow">{{ section.settings.eyebrow }}</p>
          {%- endif -%}

          <h2 class="edm-pop__title">
            {{ section.settings.title | default: 'Bienvenida a Estrella de Mar' }}
          </h2>

          {%- if section.settings.subtitle != blank -%}
            <p class="edm-pop__subtitle">{{ section.settings.subtitle }}</p>
          {%- endif -%}

          {%- if section.settings.discount_label != blank -%}
            <div class="edm-pop__pill" aria-label="Oferta: {{ section.settings.discount_label | escape }}">
              <svg class="edm-pop__pill-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/>
                <circle cx="7" cy="7" r="1.2" fill="currentColor"/>
              </svg>
              {{ section.settings.discount_label }}
            </div>
          {%- endif -%}

          <form
            @submit.prevent="subscribe()"
            class="edm-pop__form"
            novalidate
          >
            <label for="edm-pop-email" class="visually-hidden">Correo electrónico</label>
            <input
              id="edm-pop-email"
              type="email"
              x-model="email"
              class="edm-pop__input"
              placeholder="{{ section.settings.email_placeholder | default: 'Tu correo electrónico' }}"
              required
              autocomplete="email"
            >
            <button
              type="submit"
              class="edm-pop__cta"
              :disabled="loading"
            >
              <span x-show="!loading">{{ section.settings.cta_label | default: 'Obtener mi descuento' }}</span>
              <span x-show="loading" class="edm-pop__dots" aria-hidden="true">
                <span></span><span></span><span></span>
              </span>
            </button>
          </form>

          <p class="edm-pop__fine">Sin spam &middot; Cancela cuando quieras</p>
        </div>

        <div x-show="success" x-cloak class="edm-pop__success">
          <div class="edm-pop__check" aria-hidden="true">
            <svg viewBox="0 0 56 56" fill="none">
              <circle class="edm-pop__check-ring" cx="28" cy="28" r="26"/>
              <path class="edm-pop__check-mark" d="M17 28l8 9 15-17"/>
            </svg>
          </div>
          <h3 class="edm-pop__success-hdg">
            {{ section.settings.success_title | default: '¡Listo! Tu código:' }}
          </h3>
          <button
            type="button"
            class="edm-pop__code"
            :class="{ 'edm-pop__code--copied': copied }"
            @click="copyCode('{{ section.settings.discount_code | default: 'BIENVENIDA10' }}')"
            :aria-label="copied ? 'Código copiado' : 'Clic para copiar el código {{ section.settings.discount_code | default: 'BIENVENIDA10' | escape }}'"
          >
            <span class="edm-pop__code-text" x-text="copied ? '¡Copiado! ✓' : '{{ section.settings.discount_code | default: 'BIENVENIDA10' }}'"></span>
            <svg x-show="!copied" class="edm-pop__copy-icon" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <rect x="7" y="7" width="11" height="11" rx="1.5"/>
              <path d="M4 13H3a1.5 1.5 0 01-1.5-1.5V3A1.5 1.5 0 013 1.5h8.5A1.5 1.5 0 0113 3v1"/>
            </svg>
          </button>
          <p class="edm-pop__success-note">
            {{ section.settings.success_message | default: 'Aplica automáticamente en tu próxima compra.' }}
          </p>
          <button type="button" class="edm-pop__cta" @click="dismiss()">
            {{ section.settings.success_cta | default: 'Ir a la tienda' }}
          </button>
        </div>

      </div>
    </div>
  </div>
</div>
{%- endunless -%}

<script>
function edmWelcomePopup(cooldownDays) {
  return {
    open: false,
    success: false,
    loading: false,
    email: '',
    copied: false,
    _key: 'edm_pop_v2',

    init() {
      if (this.getCookie(this._key)) return;
      if (window.location.pathname.startsWith('/checkout')) return;
      setTimeout(() => {
        this.open = true;
        document.body.style.overflow = 'hidden';
      }, 3000);
    },

    dismiss() {
      this.open = false;
      document.body.style.overflow = '';
      this.setCookie(this._key, '1', cooldownDays);
    },

    async subscribe() {
      if (!this.email) return;
      this.loading = true;
      try {
        const body = new URLSearchParams({
          'form_type': 'customer',
          'utf8': '✓',
          'contact[email]': this.email,
          'contact[tags]': 'newsletter',
        });
        await fetch('/contact#contact_form', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
            'X-Requested-With': 'XMLHttpRequest',
          },
          body: body.toString(),
        });
      } catch (_) {}
      this.success = true;
      this.loading = false;
      this.setCookie(this._key, '1', cooldownDays);
    },

    copyCode(code) {
      if (!navigator.clipboard) return;
      navigator.clipboard.writeText(code).then(() => {
        this.copied = true;
        setTimeout(() => { this.copied = false; }, 2200);
      });
    },

    setCookie(name, val, days) {
      const exp = new Date(Date.now() + days * 864e5).toUTCString();
      document.cookie = name + '=' + val + '; expires=' + exp + '; path=/; SameSite=Lax';
    },

    getCookie(name) {
      return document.cookie.split('; ').find(function(r) { return r.startsWith(name + '='); });
    },
  };
}
</script>

{% stylesheet %}
.edm-pop-scrim {
  position: fixed;
  inset: 0;
  z-index: 998;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 2.4rem;
  background: rgba(11, 8, 5, 0.68);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
}
.edm-pop-scrim--trans { transition: opacity 0.4s ease; }
.edm-pop-scrim--off { opacity: 0; pointer-events: none; }
.edm-pop-scrim--on  { opacity: 1; }

.edm-pop {
  position: relative;
  display: grid;
  grid-template-columns: 380px 1fr;
  width: 100%;
  max-width: 860px;
  max-height: calc(100svh - 4.8rem);
  background: #fbf8f1;
  border-radius: 20px;
  overflow: hidden;
  box-shadow:
    0 0 0 1px rgba(208,177,106,.18),
    0 8px 32px rgba(11,8,5,.18),
    0 40px 120px rgba(11,8,5,.45);
  animation: edmPopIn 0.55s cubic-bezier(0.16, 1, 0.3, 1) both;
}

@keyframes edmPopIn {
  from { opacity: 0; transform: translateY(28px) scale(0.96); }
  to   { opacity: 1; transform: none; }
}

.edm-pop__visual {
  position: relative;
  overflow: hidden;
}
.edm-pop__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.edm-pop__img-ph {
  width: 100%;
  height: 100%;
  min-height: 460px;
  background: linear-gradient(160deg, #261a0a 0%, #0b0805 70%);
}
.edm-pop__visual-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to top,
    rgba(11,8,5,.92) 0%,
    rgba(11,8,5,.4) 45%,
    transparent 75%
  );
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 3.2rem;
  gap: 0.6rem;
}
.edm-pop__visual-quote {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-style: italic;
  font-size: clamp(2.4rem, 2.8vw, 3.2rem);
  font-weight: 400;
  color: #fbf8f1;
  line-height: 1.15;
  margin: 0;
}
.edm-pop__visual-brand {
  font-size: 1.1rem;
  font-weight: 700;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: #d0b16a;
  margin: 0;
}

.edm-pop__body {
  padding: 5.2rem 4.4rem 4.8rem;
  display: flex;
  flex-direction: column;
  justify-content: center;
  overflow-y: auto;
}

.edm-pop__close {
  position: absolute;
  top: 2rem;
  right: 2rem;
  z-index: 10;
  width: 3.2rem;
  height: 3.2rem;
  border-radius: 50%;
  border: 1px solid rgba(11,8,5,.12);
  background: rgba(251,248,241,.92);
  color: #0b0805;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  backdrop-filter: blur(4px);
}
.edm-pop__close:hover {
  background: #0b0805;
  border-color: #0b0805;
  color: #fbf8f1;
}

.edm-pop__eyebrow {
  font-size: 1.1rem;
  font-weight: 700;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  color: #9d7f32;
  margin: 0 0 1.6rem;
}
.edm-pop__title {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: clamp(3rem, 3.2vw, 4rem);
  font-weight: 400;
  line-height: 1.06;
  color: #0b0805;
  margin: 0 0 1.2rem;
}
.edm-pop__subtitle {
  font-size: 1.5rem;
  color: rgba(11,8,5,.55);
  line-height: 1.6;
  margin: 0 0 2.4rem;
}

.edm-pop__pill {
  display: inline-flex;
  align-items: center;
  gap: 0.8rem;
  padding: 0.8rem 1.6rem;
  border: 1px solid rgba(208,177,106,.4);
  background: rgba(208,177,106,.07);
  border-radius: 100px;
  font-size: 1.3rem;
  font-weight: 600;
  color: #9d7f32;
  margin-bottom: 2.8rem;
}
.edm-pop__pill-icon { width: 1.5rem; height: 1.5rem; flex-shrink: 0; }

.edm-pop__form { display: flex; flex-direction: column; gap: 1.2rem; }

.edm-pop__input {
  width: 100%;
  padding: 1.4rem 1.8rem;
  border: 1.5px solid rgba(11,8,5,.14);
  border-radius: 10px;
  background: #fff;
  font-size: 1.5rem;
  color: #0b0805;
  line-height: 1;
  box-sizing: border-box;
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
  outline: none;
}
.edm-pop__input:focus {
  border-color: #9d7f32;
  box-shadow: 0 0 0 3px rgba(157,127,50,.12);
}
.edm-pop__input::placeholder { color: rgba(11,8,5,.32); }

.edm-pop__cta {
  width: 100%;
  min-height: 5.4rem;
  padding: 1.4rem 2.4rem;
  background: #0b0805;
  color: #fbf8f1;
  border: none;
  border-radius: 10px;
  font-size: 1.35rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1rem;
  transition: background 0.25s ease;
}
.edm-pop__cta:hover:not(:disabled) { background: #9d7f32; }
.edm-pop__cta:disabled { opacity: 0.55; cursor: not-allowed; }

.edm-pop__dots { display: flex; gap: 0.5rem; align-items: center; }
.edm-pop__dots span {
  width: 0.55rem; height: 0.55rem; border-radius: 50%;
  background: currentColor;
  animation: edmPopDot 1.1s ease-in-out infinite;
}
.edm-pop__dots span:nth-child(2) { animation-delay: 0.18s; }
.edm-pop__dots span:nth-child(3) { animation-delay: 0.36s; }
@keyframes edmPopDot {
  0%, 80%, 100% { transform: scale(0.5); opacity: 0.35; }
  40% { transform: scale(1); opacity: 1; }
}

.edm-pop__fine {
  font-size: 1.15rem;
  color: rgba(11,8,5,.3);
  text-align: center;
  margin: 1.4rem 0 0;
}

.edm-pop__success {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}
.edm-pop__check {
  width: 6.8rem;
  height: 6.8rem;
  margin-bottom: 2.8rem;
}
.edm-pop__check svg { width: 100%; height: 100%; overflow: visible; }
.edm-pop__check-ring {
  stroke: #d0b16a;
  stroke-width: 1.5;
  stroke-dasharray: 163;
  stroke-dashoffset: 163;
  animation: edmRing 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.1s forwards;
}
.edm-pop__check-mark {
  stroke: #9d7f32;
  stroke-width: 2.5;
  stroke-linecap: round;
  stroke-linejoin: round;
  stroke-dasharray: 46;
  stroke-dashoffset: 46;
  animation: edmMark 0.45s cubic-bezier(0.16, 1, 0.3, 1) 0.7s forwards;
}
@keyframes edmRing { to { stroke-dashoffset: 0; } }
@keyframes edmMark { to { stroke-dashoffset: 0; } }

.edm-pop__success-hdg {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: 2.8rem;
  font-weight: 400;
  color: #0b0805;
  margin: 0 0 2rem;
}

.edm-pop__code {
  display: inline-flex;
  align-items: center;
  gap: 1.2rem;
  padding: 1.4rem 2.8rem;
  border: 1.5px dashed rgba(208,177,106,.5);
  background: rgba(208,177,106,.06);
  border-radius: 12px;
  cursor: pointer;
  transition: background 0.2s ease, border-color 0.2s ease;
  margin-bottom: 1.8rem;
}
.edm-pop__code:hover { background: rgba(208,177,106,.13); border-color: #d0b16a; }
.edm-pop__code--copied { border-color: rgba(26,107,52,.5); background: rgba(26,107,52,.06); }
.edm-pop__code-text {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: 3.2rem;
  font-weight: 700;
  letter-spacing: 0.16em;
  color: #9d7f32;
  line-height: 1;
}
.edm-pop__code--copied .edm-pop__code-text { color: #1a6b34; }
.edm-pop__copy-icon { width: 1.8rem; height: 1.8rem; color: #9d7f32; flex-shrink: 0; }

.edm-pop__success-note {
  font-size: 1.45rem;
  color: rgba(11,8,5,.5);
  line-height: 1.55;
  margin: 0 0 2.8rem;
  max-width: 28rem;
}

@media (max-width: 749px) {
  .edm-pop-scrim {
    padding: 0;
    align-items: flex-end;
  }
  .edm-pop {
    grid-template-columns: 1fr;
    border-radius: 20px 20px 0 0;
    max-height: 92svh;
    overflow-y: auto;
    animation-name: edmPopInMobile;
  }
  .edm-pop__visual { height: 22rem; }
  .edm-pop__img-ph { min-height: 22rem; }
  .edm-pop__body {
    padding: 3.6rem 2.4rem 5.2rem;
    justify-content: flex-start;
  }
  .edm-pop__title { font-size: 3.2rem; }
}

@keyframes edmPopInMobile {
  from { opacity: 0; transform: translateY(48px); }
  to   { opacity: 1; transform: none; }
}
{% endstylesheet %}

