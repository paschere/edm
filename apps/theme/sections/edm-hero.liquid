{%- liquid
  assign fp           = all_products[section.settings.featured_product]
  assign raw_heading  = section.settings.heading | default: 'Bronceado dorado, nacido en el Caribe'
  assign heading_words = raw_heading | split: ' '
  assign gold_csv     = section.settings.heading_gold_words | downcase | strip
  assign gold_list    = gold_csv | split: ','
  assign widx         = 0
-%}

<section
  class="edm-hero color-{{ section.settings.color_scheme }} gradient"
  style="--pt:{{ section.settings.padding_top }}px;--pb:{{ section.settings.padding_bottom }}px;padding-top:var(--pt);padding-bottom:var(--pb);"
  aria-label="{{ raw_heading | escape }}"
>
  <div class="edm-hero__grid">

    <div class="edm-hero__copy">

      {%- if section.settings.eyebrow != blank -%}
        <p class="edm-hero__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      <h1 class="edm-hero__h1" aria-label="{{ raw_heading | escape }}">
        {%- for w in heading_words -%}
          {%- assign wc = w | remove: ',' | remove: '.' | remove: '!' | remove: '¡' | downcase -%}
          {%- assign is_gold = false -%}
          {%- for g in gold_list -%}
            {%- if g == wc -%}{%- assign is_gold = true -%}{%- endif -%}
          {%- endfor -%}
          <span class="edm-word-mask"><span class="edm-word{% if is_gold %} edm-word--gold{% endif %}" style="--i:{{ widx }}">{{ w }}</span></span>
          {%- assign widx = widx | plus: 1 -%}
        {%- endfor -%}
      </h1>

      {%- if section.settings.lead != blank -%}
        <p class="edm-hero__lead">{{ section.settings.lead }}</p>
      {%- endif -%}

      <div class="edm-hero__ctas">
        {%- if section.settings.cta_primary_label != blank -%}
          <a href="{{ section.settings.cta_primary_url | default: '#' }}" class="edm-hero__btn-primary">
            <span>{{ section.settings.cta_primary_label }}</span>
          </a>
        {%- endif -%}
        {%- if section.settings.cta_secondary_label != blank -%}
          <a href="{{ section.settings.cta_secondary_url | default: '#' }}" class="edm-hero__btn-ghost">
            {{ section.settings.cta_secondary_label }}
          </a>
        {%- endif -%}
      </div>

      {%- if section.blocks.size > 0 -%}
        <div class="edm-hero__stats">
          {%- for block in section.blocks -%}
            {%- if block.type == 'stat' -%}
              <div class="edm-hero__stat" {{ block.shopify_attributes }}>
                <span class="edm-hero__stat-val">{{ block.settings.value }}</span>
                <span class="edm-hero__stat-lbl">{{ block.settings.label }}</span>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

      <div class="edm-hero__scroll" aria-hidden="true">
        <span class="edm-hero__scroll-line"></span>
        <span class="edm-hero__scroll-lbl">Scroll</span>
      </div>

    </div>

    <div class="edm-hero__media">
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 1400
          | image_tag:
            loading: 'eager',
            fetchpriority: 'high',
            width: 1400,
            class: 'edm-hero__img',
            alt: section.settings.image.alt | default: 'Estrella de Mar'
        }}
      {%- else -%}
        <div class="edm-hero__placeholder" aria-hidden="true">
          <span class="edm-hero__placeholder-label">Estrella de Mar</span>
        </div>
      {%- endif -%}

      <div class="edm-hero__wash" aria-hidden="true"></div>
      <div class="edm-hero__vignette" aria-hidden="true"></div>

      {%- if section.settings.accent_text != blank -%}
        <p class="edm-hero__accent" aria-hidden="true">
          <span class="edm-hero__spark">✦</span>
          {{ section.settings.accent_text }}
        </p>
      {%- endif -%}

      {%- if fp != empty -%}
        <a href="{{ fp.url }}" class="edm-hero__pf" aria-label="{{ fp.title | escape }}">
          <div class="edm-hpf__media">
            {%- if section.settings.featured_product_chip != blank -%}
              <span class="edm-hpf__chip">{{ section.settings.featured_product_chip }}</span>
            {%- endif -%}
            {%- if fp.featured_image -%}
              {{
                fp.featured_image
                | image_url: width: 400
                | image_tag:
                  loading: 'lazy',
                  width: 400,
                  class: 'edm-hpf__img',
                  alt: fp.title
              }}
            {%- endif -%}
          </div>
          <div class="edm-hpf__body">
            {%- if section.settings.featured_product_category != blank -%}
              <p class="edm-hpf__cat">{{ section.settings.featured_product_category }}</p>
            {%- endif -%}
            <p class="edm-hpf__name">{{ fp.title }}</p>
          </div>
          <div class="edm-hpf__foot">
            <span class="edm-hpf__price">{{ fp.price | money_without_trailing_zeros }}</span>
            <span class="edm-hpf__shop">Comprar <span class="edm-hpf__arrow">→</span></span>
          </div>
        </a>
      {%- endif -%}

    </div>
  </div>
</section>

{% stylesheet %}
  .edm-hero { overflow: hidden; }

  .edm-hero__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: min(95vh, 960px);
  }

  .edm-hero__copy {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 6rem 5rem 5rem 7%;
  }

  .edm-hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 1.2rem;
    font-size: 1.3rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #9d7f32;
    font-weight: 600;
    margin: 0 0 3rem;
    animation: edmHeroFade 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.1s both;
  }
  .edm-hero__eyebrow::before {
    content: '';
    width: 36px;
    height: 1px;
    background: currentColor;
    flex-shrink: 0;
  }

  @keyframes edmHeroFade {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .edm-hero__h1 {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(6.4rem, 8vw, 12rem);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.015em;
    color: #0b0805;
    margin: 0 0 3rem;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0 0.22em;
  }

  .edm-word-mask {
    display: block;
    overflow: hidden;
    line-height: inherit;
    padding-bottom: 0.12em;
  }

  .edm-word {
    display: inline-block;
    transform: translateY(110%);
    opacity: 0;
    animation: edmWordUp 1.1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: calc(0.15s + var(--i, 0) * 0.1s);
  }

  @keyframes edmWordUp {
    0%   { transform: translateY(110%); opacity: 0; }
    40%  { opacity: 1; }
    100% { transform: translateY(0); opacity: 1; }
  }

  .edm-word--gold {
    font-style: italic;
    font-weight: 500;
    background: linear-gradient(100deg, #9d7f32 0%, #bb9a4c 25%, #e3c990 50%, #bb9a4c 75%, #9d7f32 100%);
    background-size: 250% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    animation: edmWordUp 1.1s cubic-bezier(0.22, 1, 0.36, 1) forwards, edmGoldShine 5s ease-in-out infinite;
    animation-delay: calc(0.15s + var(--i, 0) * 0.1s), calc(1.4s + var(--i, 0) * 0.3s);
  }

  @keyframes edmGoldShine {
    0%, 100% { background-position: 0% 50%; }
    50%       { background-position: 200% 50%; }
  }

  .edm-hero__lead {
    font-size: 1.8rem;
    color: #4a3f2f;
    max-width: 520px;
    margin: 0 0 3.5rem;
    line-height: 1.75;
  }

  .edm-hero__ctas {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin: 0 0 4rem;
  }

  .edm-hero__btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1.6rem 3.2rem;
    font-size: 1.25rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 700;
    border-radius: 2px;
    border: none;
    cursor: pointer;
    text-decoration: none;
    position: relative;
    overflow: hidden;
    background: #0b0805;
    color: #fbf8f1;
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.3s;
  }
  .edm-hero__btn-primary span { position: relative; z-index: 1; transition: color 0.3s; }
  .edm-hero__btn-primary::after {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(135deg, #d0b16a, #9d7f32);
    opacity: 0;
    transition: opacity 0.3s;
  }
  .edm-hero__btn-primary:hover::after { opacity: 1; }
  .edm-hero__btn-primary:hover span { color: #0b0805; }
  .edm-hero__btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 28px -10px rgba(157, 127, 50, 0.5);
  }

  .edm-hero__btn-ghost {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1.6rem 3.2rem;
    font-size: 1.25rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 700;
    border-radius: 2px;
    border: 1.5px solid #0b0805;
    background: transparent;
    color: #0b0805;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .edm-hero__btn-ghost:hover {
    background: #0b0805;
    color: #fbf8f1;
    transform: translateY(-2px);
  }

  .edm-hero__stats {
    display: flex;
    gap: 3.5rem;
    flex-wrap: wrap;
    padding-top: 3rem;
    border-top: 1px solid rgba(11, 8, 5, 0.1);
  }
  .edm-hero__stat {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .edm-hero__stat-val {
    font-family: 'Cormorant Garamond', serif;
    font-size: 4.2rem;
    font-weight: 500;
    font-style: italic;
    color: #0b0805;
    line-height: 1;
  }
  .edm-hero__stat-lbl {
    font-size: 1.25rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #78695a;
    font-weight: 500;
  }

  .edm-hero__media {
    position: relative;
    overflow: hidden;
    background: #c8935a;
  }

  .edm-hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    animation: edmSlowZoom 18s ease-out infinite alternate;
  }
  @keyframes edmSlowZoom {
    from { transform: scale(1); }
    to   { transform: scale(1.06); }
  }

  .edm-hero__placeholder {
    width: 100%;
    height: 100%;
    min-height: 480px;
    background: linear-gradient(145deg, #d4954e 0%, #e8aa5c 20%, #c47830 50%, #a85e20 75%, #7a3e10 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .edm-hero__placeholder-label {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.4rem;
    font-style: italic;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(251, 248, 241, 0.45);
  }

  .edm-hero__wash {
    position: absolute; inset: 0; z-index: 2; pointer-events: none;
    background: linear-gradient(120deg, rgba(244, 238, 225, 0.38) 0%, transparent 25%);
  }
  .edm-hero__vignette {
    position: absolute; inset: 0; z-index: 2; pointer-events: none;
    background:
      linear-gradient(180deg, transparent 35%, rgba(11, 8, 5, 0.42) 100%),
      radial-gradient(ellipse at 75% 95%, rgba(11, 8, 5, 0.38) 0%, transparent 52%);
  }

  .edm-hero__accent {
    position: absolute; top: 2.5rem; left: 2.5rem; z-index: 3;
    display: inline-flex; align-items: center; gap: 0.8rem;
    margin: 0;
    color: rgba(251, 248, 241, 0.9);
    font-size: 1.1rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    font-weight: 600;
    text-shadow: 0 1px 10px rgba(11, 8, 5, 0.5);
    animation: edmHeroFade 1.2s ease-out 0.8s both;
  }
  .edm-hero__spark { color: #d0b16a; }

  .edm-hero__pf {
    position: absolute; bottom: 3rem; right: 3rem; z-index: 4;
    width: 300px;
    background: #fbf8f1;
    border-radius: 4px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: #0b0805;
    box-shadow: 0 2px 4px rgba(11, 8, 5, 0.08), 0 24px 56px -14px rgba(11, 8, 5, 0.5);
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.4s;
    animation: edmWidgetEntry 0.9s cubic-bezier(0.22, 1, 0.36, 1) 1.2s both;
  }
  .edm-hero__pf:hover {
    transform: translateY(-8px);
    box-shadow: 0 2px 4px rgba(11, 8, 5, 0.1), 0 36px 72px -14px rgba(11, 8, 5, 0.6);
  }
  @keyframes edmWidgetEntry {
    from { opacity: 0; transform: translateY(28px) translateX(16px); }
    to   { opacity: 1; transform: none; }
  }

  .edm-hpf__media {
    position: relative;
    width: 100%;
    aspect-ratio: 5/4;
    background: radial-gradient(circle at 50% 40%, #f9f1e0, #ede0c5);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .edm-hpf__img {
    max-width: 55%;
    max-height: 85%;
    object-fit: contain;
    mix-blend-mode: multiply;
    filter: drop-shadow(0 8px 18px rgba(11, 8, 5, 0.2));
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
    position: relative;
    z-index: 1;
  }
  .edm-hero__pf:hover .edm-hpf__img { transform: scale(1.06); }

  .edm-hpf__chip {
    position: absolute; top: 1.2rem; left: 1.2rem; z-index: 2;
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 6px 12px;
    background: rgba(11, 8, 5, 0.88);
    color: #d0b16a;
    font-size: 1rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 700;
    border-radius: 50px;
  }
  .edm-hpf__chip::before {
    content: '';
    width: 6px; height: 6px;
    background: #d0b16a;
    border-radius: 50%;
    box-shadow: 0 0 5px #d0b16a;
  }

  .edm-hpf__body { padding: 1.6rem 1.8rem 1rem; }
  .edm-hpf__cat {
    font-size: 1rem; letter-spacing: 0.26em; text-transform: uppercase;
    color: #9d7f32; font-weight: 600; margin: 0 0 0.4rem;
  }
  .edm-hpf__name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.4rem; font-weight: 500; font-style: italic;
    color: #0b0805; line-height: 1.1; margin: 0;
  }

  .edm-hpf__foot {
    display: flex; align-items: center; justify-content: space-between;
    padding: 1.2rem 1.8rem 1.6rem;
    border-top: 1px solid rgba(11, 8, 5, 0.08);
    margin-top: 0.8rem;
  }
  .edm-hpf__price {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.2rem; font-weight: 500; font-style: italic;
    color: #0b0805; margin: 0;
  }
  .edm-hpf__shop {
    font-size: 1.1rem; letter-spacing: 0.22em; text-transform: uppercase;
    color: #0b0805; font-weight: 700;
    position: relative; padding-bottom: 3px;
    transition: color 0.25s;
  }
  .edm-hpf__shop::after {
    content: ''; position: absolute; bottom: 0; left: 0; right: 0;
    height: 1px; background: #0b0805; transition: background 0.25s;
  }
  .edm-hero__pf:hover .edm-hpf__shop { color: #9d7f32; }
  .edm-hero__pf:hover .edm-hpf__shop::after { background: #9d7f32; }
  .edm-hpf__arrow {
    display: inline-block;
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .edm-hero__pf:hover .edm-hpf__arrow { transform: translateX(3px); }

  .edm-hero__scroll {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.2rem;
    padding-top: 4rem;
    animation: edmHeroFade 1s ease-out 2.2s both;
  }
  .edm-hero__scroll-line {
    width: 1px;
    height: 5.6rem;
    background: linear-gradient(to bottom, #9d7f32, transparent);
    animation: edmScrollPulse 2.2s ease-in-out 3s infinite;
  }
  @keyframes edmScrollPulse {
    0%   { transform: scaleY(1) translateY(0); opacity: 1; }
    60%  { transform: scaleY(0.4) translateY(60%); opacity: 0.3; }
    100% { transform: scaleY(1) translateY(0); opacity: 1; }
  }
  .edm-hero__scroll-lbl {
    font-size: 1.15rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    font-weight: 600;
    color: #78695a;
    writing-mode: vertical-rl;
    text-orientation: mixed;
  }

  @media (max-width: 749px) {
    .edm-hero__grid {
      grid-template-columns: 1fr;
      min-height: auto;
    }
    .edm-hero__media {
      height: 65vw;
      min-height: 280px;
      order: -1;
    }
    .edm-hero__copy { padding: 4rem 2.4rem 4rem; justify-content: flex-start; }
    .edm-hero__h1 { font-size: clamp(5rem, 14vw, 8rem); gap: 0 0.2em; }
    .edm-hero__lead { font-size: 1.6rem; }
    .edm-hero__pf { display: none; }
    .edm-hero__stats { gap: 2.5rem; }
    .edm-hero__stat-val { font-size: 3.6rem; }
    .edm-hero__scroll { display: none; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero editorial",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Texto"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texto sobre el título",
      "default": "The Colombian Tanning Ritual"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titular",
      "default": "Bronceado dorado, nacido en el Caribe"
    },
    {
      "type": "text",
      "id": "heading_gold_words",
      "label": "Palabras en dorado (separar por coma)",
      "default": "dorado,caribe",
      "info": "Escribe las palabras del titular que deben aparecer en dorado. Ej: dorado,caribe"
    },
    {
      "type": "textarea",
      "id": "lead",
      "label": "Párrafo lead",
      "default": "Aceites y bronceadores naturales formulados con zanahoria, coco y extractos del trópico colombiano. Un ritual solar pensado para honrar la piel y el mar."
    },
    {
      "type": "header",
      "content": "CTAs"
    },
    {
      "type": "text",
      "id": "cta_primary_label",
      "label": "Botón principal",
      "default": "Comprar ritual"
    },
    {
      "type": "url",
      "id": "cta_primary_url",
      "label": "Destino botón principal"
    },
    {
      "type": "text",
      "id": "cta_secondary_label",
      "label": "Botón secundario",
      "default": "Nuestra historia"
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "Destino botón secundario"
    },
    {
      "type": "header",
      "content": "Imagen"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen del hero"
    },
    {
      "type": "text",
      "id": "accent_text",
      "label": "Texto acento sobre la imagen",
      "default": "Est. MMXX · Medellín"
    },
    {
      "type": "header",
      "content": "Producto destacado"
    },
    {
      "type": "product",
      "id": "featured_product",
      "label": "Producto en tarjeta flotante"
    },
    {
      "type": "text",
      "id": "featured_product_category",
      "label": "Categoría del producto",
      "default": "Bronceador"
    },
    {
      "type": "text",
      "id": "featured_product_chip",
      "label": "Chip del producto",
      "default": "Best Seller"
    },
    {
      "type": "header",
      "content": "Diseño"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Esquema de color",
      "options": [
        { "value": "scheme-1", "label": "Bone / Ivory" },
        { "value": "scheme-2", "label": "Sand" },
        { "value": "scheme-3", "label": "Oscuro" }
      ],
      "default": "scheme-2"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding superior",
      "min": 0, "max": 80, "step": 4, "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding inferior",
      "min": 0, "max": 80, "step": 4, "unit": "px",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Dato / cifra",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "value",
          "label": "Valor",
          "default": "4.9 ★"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Etiqueta",
          "default": "1.842 reviews"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero editorial",
