{%- liquid
  assign raw_heading   = section.settings.heading | default: 'Bronceado dorado, nacido en el Caribe'
  assign heading_words = raw_heading | split: ' '
  assign script_csv    = section.settings.heading_gold_words | downcase | strip
  assign script_list   = script_csv | split: ','
  assign widx          = 0
-%}

{%- liquid
  assign has_video_file = false
  assign has_video_url  = false
  if section.settings.video != blank
    assign has_video_file = true
  endif
  if section.settings.video_url != blank
    assign has_video_url = true
  endif
  assign has_media = false
  if has_video_file or has_video_url or section.settings.image != blank
    assign has_media = true
  endif
-%}

{%- assign overlay_pct = section.settings.overlay_strength | default: 65 -%}
{%- assign overlay_dec = overlay_pct | times: 1.0 | divided_by: 100.0 -%}
{%- assign media_opacity = 100 | minus: overlay_pct | times: 1.0 | divided_by: 100.0 -%}

<section
  class="edm-hero{% if has_media %} edm-hero--has-img{% endif %}"
  style="--pt:{{ section.settings.padding_top }}px;--pb:{{ section.settings.padding_bottom }}px;--min-h:{{ section.settings.min_height }}px;--overlay:{{ overlay_dec }};--media-op:{{ media_opacity }};padding-top:var(--pt);padding-bottom:var(--pb);"
  aria-label="{{ raw_heading | escape }}"
>
  <div class="edm-hero__bg" aria-hidden="true">
    {%- if has_video_file -%}
      {{
        section.settings.video
        | video_tag:
          autoplay: true,
          loop: true,
          muted: true,
          playsinline: true,
          controls: false,
          preload: 'auto',
          image_size: '2400x',
          class: 'edm-hero__bg-video'
      }}
    {%- elsif has_video_url -%}
      {%- assign vu = section.settings.video_url -%}
      {%- if vu.type == 'youtube' -%}
        <iframe class="edm-hero__bg-iframe"
          src="https://www.youtube.com/embed/{{ vu.id }}?autoplay=1&mute=1&loop=1&playlist={{ vu.id }}&controls=0&showinfo=0&modestbranding=1&playsinline=1&rel=0&wmode=opaque"
          frameborder="0" allow="autoplay; encrypted-media" allowfullscreen aria-hidden="true" tabindex="-1"></iframe>
      {%- elsif vu.type == 'vimeo' -%}
        <iframe class="edm-hero__bg-iframe"
          src="https://player.vimeo.com/video/{{ vu.id }}?autoplay=1&loop=1&muted=1&background=1&autopause=0"
          frameborder="0" allow="autoplay; encrypted-media" allowfullscreen aria-hidden="true" tabindex="-1"></iframe>
      {%- endif -%}
    {%- elsif section.settings.image != blank -%}
      {{
        section.settings.image
        | image_url: width: 2400
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          width: 2400,
          class: 'edm-hero__bg-img',
          alt: ''
      }}
    {%- endif -%}

  </div>

  <div class="edm-hero__deco" aria-hidden="true">
    {%- render 'edm-confetti', class: 'edm-hero__confetti' -%}
    <div class="edm-hero__palm edm-hero__palm--l edm-anim-palm-sway">
      {%- render 'edm-palm' -%}
    </div>
    <div class="edm-hero__palm edm-hero__palm--r edm-anim-palm-sway-r">
      {%- render 'edm-palm' -%}
    </div>
    <div class="edm-hero__star edm-hero__star--tl">{%- render 'edm-starfish', stroke: 'rgba(255,255,255,0.55)' -%}</div>
    <div class="edm-hero__star edm-hero__star--br">{%- render 'edm-starfish', stroke: 'rgba(255,255,255,0.55)' -%}</div>
    {%- render 'edm-sparkle', class: 'edm-hero__spark edm-hero__spark--1' -%}
    {%- render 'edm-sparkle', class: 'edm-hero__spark edm-hero__spark--2' -%}
    {%- render 'edm-sparkle', class: 'edm-hero__spark edm-hero__spark--3' -%}
  </div>

  <div class="edm-hero__inner">

    {%- if section.settings.mini_ribbon_pre != blank or section.settings.mini_ribbon_script != blank -%}
      <div class="edm-hero__chip">
        {%- render 'edm-starfish', class: 'edm-hero__chip-icon' -%}
        <span>
          {{ section.settings.mini_ribbon_pre }}
          {%- if section.settings.mini_ribbon_script != blank -%}
            <em class="edm-script edm-hero__chip-script">{{ section.settings.mini_ribbon_script }}</em>
          {%- endif -%}
        </span>
        {%- render 'edm-sparkle', class: 'edm-hero__chip-icon edm-hero__chip-icon--spark' -%}
      </div>
    {%- endif -%}

    {%- if section.settings.eyebrow != blank -%}
      <p class="edm-hero__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}

    <h1 class="edm-hero__h1" aria-label="{{ raw_heading | escape }}">
      {%- for w in heading_words -%}
        {%- assign wc = w | remove: ',' | remove: '.' | remove: '!' | remove: '¡' | downcase -%}
        {%- assign is_script = false -%}
        {%- for g in script_list -%}
          {%- if g == wc -%}{%- assign is_script = true -%}{%- endif -%}
        {%- endfor -%}
        {%- if is_script -%}
          <span class="edm-script edm-hero__word-script">{{ w }}</span>
        {%- else -%}
          {{ w }}
        {%- endif -%}
        {%- unless forloop.last %} {% endunless -%}
      {%- endfor -%}
    </h1>

    {%- if section.settings.lead != blank -%}
      <p class="edm-hero__lead">{{ section.settings.lead }}</p>
    {%- endif -%}

    {%- if section.settings.show_rating -%}
      <div class="edm-hero__rating" aria-label="Rating: {{ section.settings.rating_value }} de 5 estrellas">
        <span class="edm-hero__rating-stars" aria-hidden="true">
          {%- for i in (1..5) -%}
            <svg viewBox="0 0 20 20" fill="currentColor"><path d="M10 1.5l2.7 5.5 6 .9-4.4 4.2 1.1 6-5.4-2.8-5.4 2.8 1.1-6L1.3 7.9l6-.9z"/></svg>
          {%- endfor -%}
        </span>
        <span class="edm-hero__rating-text">
          <strong>{{ section.settings.rating_value | default: '4.9' }}</strong>
          {{ section.settings.rating_label | default: 'de 5' }}
          <span class="edm-hero__rating-sep">·</span>
          {{ section.settings.rating_count | default: '+1.842 reseñas' }}
        </span>
      </div>
    {%- endif -%}

    <div class="edm-hero__ctas">
      {%- if section.settings.cta_primary_label != blank -%}
        <a href="{{ section.settings.cta_primary_url | default: '#' }}" class="edm-hero__btn-primary">
          {{ section.settings.cta_primary_label }}
        </a>
      {%- endif -%}
      {%- if section.settings.cta_secondary_label != blank -%}
        <a href="{{ section.settings.cta_secondary_url | default: '#' }}" class="edm-hero__btn-ghost">
          {{ section.settings.cta_secondary_label }}
        </a>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="edm-hero__stats">
        {%- for block in section.blocks -%}
          {%- if block.type == 'stat' -%}
            <div class="edm-hero__stat" {{ block.shopify_attributes }}>
              <span class="edm-hero__stat-val">{{ block.settings.value }}</span>
              <span class="edm-hero__stat-lbl">{{ block.settings.label }}</span>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

{% stylesheet %}
.edm-hero {
  position: relative;
  isolation: isolate;
  overflow: hidden;
  text-align: center;
  color: #fff;
  background: #FF88BB;
  min-height: calc(100vh - 13rem);
  min-height: calc(100dvh - 13rem);
  display: flex;
  align-items: center;
  justify-content: center;
}

.edm-hero__bg {
  position: absolute;
  inset: 0;
  z-index: 0;
  overflow: hidden;
  /* Pink lives HERE as the wrapper background — the media on top is faded with opacity so the pink shows through. Bulletproof: works for <video>, <img>, <iframe> regardless of compositing layer. */
  background: linear-gradient(135deg, #FFA5D3 0%, #FF88BB 45%, #FF9966 100%);
}
.edm-hero__bg-img,
.edm-hero__bg-video,
.edm-hero__bg-iframe {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  pointer-events: none;
  z-index: 1;
}
.edm-hero--has-img .edm-hero__bg-img,
.edm-hero--has-img .edm-hero__bg-video,
.edm-hero--has-img .edm-hero__bg-iframe {
  opacity: var(--media-op, 0.35);
}
.edm-hero__bg-iframe { border: 0; }
.edm-hero__bg-video > video,
.edm-hero__bg-video video {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
@media (min-aspect-ratio: 16/9) {
  .edm-hero__bg-iframe { height: 56.25vw; top: 50%; bottom: auto; transform: translateY(-50%); }
}
@media (max-aspect-ratio: 16/9) {
  .edm-hero__bg-iframe { width: 177.78vh; left: 50%; right: auto; transform: translateX(-50%); }
}


.edm-hero__deco {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 6;
  transform: translateZ(0);
}
.edm-hero__confetti {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  color: rgba(255,255,255,0.5);
  opacity: 0.7;
}
.edm-hero__palm {
  position: absolute;
  width: 22rem;
  height: 38rem;
  color: rgba(255,255,255,0.55);
  filter: drop-shadow(0 8px 22px rgba(255,136,187,0.45));
  pointer-events: none;
  z-index: 0;
}
.edm-hero__palm svg { width: 100%; height: 100%; }
.edm-hero__palm--l {
  top: -4rem;
  left: -3rem;
  transform-origin: top left;
}
.edm-hero__palm--r {
  bottom: -5rem;
  right: -3rem;
  transform-origin: bottom right;
  transform: scaleX(-1);
}

.edm-hero__star {
  position: absolute;
  width: 14rem;
  height: 14rem;
  color: rgba(255,255,255,0.5);
  filter: drop-shadow(0 4px 16px rgba(255,136,187,0.4));
}
.edm-hero__star svg { width: 100%; height: 100%; }
.edm-hero__star--tl {
  top: 6%;
  left: 5%;
  transform: rotate(-15deg);
  animation: edmHeroStarFloat 9s ease-in-out infinite;
}
.edm-hero__star--br {
  bottom: 6%;
  right: 5%;
  transform: rotate(20deg);
  width: 11rem;
  height: 11rem;
  animation: edmHeroStarFloat 11s ease-in-out infinite reverse;
}
@keyframes edmHeroStarFloat {
  0%, 100% { transform: translateY(0) rotate(-15deg); }
  50%       { transform: translateY(-10px) rotate(-10deg); }
}

.edm-hero__spark {
  position: absolute;
  color: #fff;
  filter: drop-shadow(0 2px 8px rgba(255,153,102,0.5));
  animation: edmTwinkle 3s ease-in-out infinite;
}
.edm-hero__spark--1 {
  top: 22%; left: 18%;
  width: 1.8rem;
  animation-delay: 0.2s;
}
.edm-hero__spark--2 {
  top: 30%; right: 22%;
  width: 1.4rem;
  animation-delay: 1.1s;
}
.edm-hero__spark--3 {
  bottom: 24%; left: 28%;
  width: 1.5rem;
  animation-delay: 2.0s;
}
@keyframes edmTwinkle {
  0%, 100% { opacity: 0.4; transform: scale(0.85) rotate(0deg); }
  50%       { opacity: 1; transform: scale(1.15) rotate(45deg); }
}

.edm-hero__inner {
  max-width: 860px;
  padding: 8rem 2.4rem;
  position: relative;
  z-index: 7;
  transform: translateZ(0);
}

.edm-hero__chip {
  display: inline-flex;
  align-items: center;
  gap: 0.7rem;
  padding: 0.7rem 1.6rem 0.7rem 1.2rem;
  background: rgba(255,255,255,0.96);
  color: #FF88BB;
  border-radius: 100px;
  font-size: 1.1rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  font-weight: 700;
  margin: 0 0 2rem;
  box-shadow: 0 8px 22px -8px rgba(255,136,187,0.55);
  animation: edmHeroFade 0.8s cubic-bezier(0.22, 1, 0.36, 1) both;
}
.edm-hero__chip-icon {
  width: 1.4rem;
  height: 1.4rem;
  flex-shrink: 0;
  color: #FF88BB;
}
.edm-hero__chip-icon--spark {
  width: 1.1rem;
  height: 1.1rem;
  color: #FF9966;
  animation: edmTwinkle 2.4s ease-in-out infinite 0.4s;
}
.edm-hero__chip-script {
  font-style: normal;
  text-transform: lowercase;
  font-size: 1.45em;
  letter-spacing: 0;
  margin: 0 0.1em;
  line-height: 1;
  display: inline-block;
  transform: translateY(0.08em);
  color: #FF9966;
}

@keyframes edmHeroFade {
  from { opacity: 0; transform: translateY(14px); }
  to   { opacity: 1; transform: translateY(0); }
}

.edm-hero__eyebrow {
  font-size: 1.2rem;
  letter-spacing: 0.32em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.92);
  font-weight: 600;
  margin: 0 0 1.8rem;
  text-shadow: 0 1px 8px rgba(255,136,187,0.35);
  animation: edmHeroFade 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.1s both;
}

.edm-hero__h1 {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: clamp(4.6rem, 7vw, 9rem);
  font-weight: 400;
  line-height: 1.05;
  letter-spacing: -0.015em;
  color: #fff;
  margin: 0 0 2.6rem;
  text-shadow: 0 4px 24px rgba(255,136,187,0.4);
  animation: edmHeroFade 1s cubic-bezier(0.22, 1, 0.36, 1) 0.2s both;
}
.edm-hero__word-script {
  font-size: 1.2em;
  display: inline-block;
  transform: translateY(0.08em);
  margin: 0 0.05em;
  text-shadow: 0 4px 24px rgba(255,153,102,0.5);
}

.edm-hero__lead {
  font-size: 1.7rem;
  line-height: 1.7;
  color: rgba(255,255,255,0.95);
  max-width: 580px;
  margin: 0 auto 2.4rem;
  text-shadow: 0 1px 10px rgba(255,136,187,0.3);
  animation: edmHeroFade 1s ease-out 0.4s both;
}

.edm-hero__rating {
  display: inline-flex;
  align-items: center;
  gap: 0.8rem;
  margin: 0 auto 2.4rem;
  font-size: 1.2rem;
  color: #fff;
  text-shadow: 0 1px 8px rgba(255,136,187,0.3);
  animation: edmHeroFade 1s ease-out 0.5s both;
}
.edm-hero__rating-stars {
  display: inline-flex;
  align-items: center;
  gap: 0.18rem;
  color: #fff;
  filter: drop-shadow(0 2px 4px rgba(255,136,187,0.45));
}
.edm-hero__rating-stars svg {
  width: 1.6rem;
  height: 1.6rem;
}
.edm-hero__rating-text {
  letter-spacing: 0.04em;
  font-weight: 500;
}
.edm-hero__rating-text strong {
  font-weight: 700;
  font-size: 1.3rem;
}
.edm-hero__rating-sep {
  margin: 0 0.4rem;
  opacity: 0.7;
}

.edm-hero__ctas {
  display: flex;
  gap: 1.4rem;
  justify-content: center;
  flex-wrap: wrap;
  margin: 0 0 3.6rem;
  animation: edmHeroFade 1s ease-out 0.55s both;
}

.edm-hero__btn-primary,
.edm-hero__btn-ghost {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 1.6rem 3.2rem;
  font-size: 1.25rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  font-weight: 700;
  border-radius: 100px;
  text-decoration: none;
  transition: transform 0.25s, box-shadow 0.25s, background 0.25s;
}
.edm-hero__btn-primary {
  background: #fff;
  color: #FF88BB;
  border: none;
  box-shadow: 0 12px 30px -10px rgba(255,136,187,0.6);
}
.edm-hero__btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 18px 36px -10px rgba(255,136,187,0.7);
}
.edm-hero__btn-ghost {
  border: 2px solid rgba(255,255,255,0.85);
  background: transparent;
  color: #fff;
}
.edm-hero__btn-ghost:hover {
  background: rgba(255,255,255,0.18);
  transform: translateY(-2px);
}

.edm-hero__stats {
  display: flex;
  gap: 3.2rem;
  flex-wrap: wrap;
  justify-content: center;
  padding-top: 2.8rem;
  border-top: 1px solid rgba(255,255,255,0.3);
  animation: edmHeroFade 1s ease-out 0.7s both;
}
.edm-hero__stat {
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
}
.edm-hero__stat-val {
  font-family: 'Cormorant Garamond', serif;
  font-size: 3.4rem;
  font-weight: 500;
  font-style: italic;
  color: #fff;
  line-height: 1;
  text-shadow: 0 2px 12px rgba(255,136,187,0.3);
}
.edm-hero__stat-lbl {
  font-size: 1.1rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.78);
  font-weight: 600;
}

@media (max-width: 749px) {
  .edm-hero__inner { padding: 5rem 2rem; }
  .edm-hero__h1 { font-size: clamp(4.4rem, 12vw, 6.6rem); }
  .edm-hero__lead { font-size: 1.55rem; }
  .edm-hero__star--tl { width: 8rem; height: 8rem; top: 3%; left: 3%; }
  .edm-hero__star--br { width: 6rem; height: 6rem; bottom: 3%; right: 3%; }
  .edm-hero__palm { width: 14rem; height: 24rem; }
  .edm-hero__palm--l { top: -2rem; left: -4rem; }
  .edm-hero__palm--r { bottom: -3rem; right: -4rem; }
  .edm-hero__stats { gap: 2rem; }
  .edm-hero__stat-val { font-size: 2.8rem; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Hero (sencillo · sunset)",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Mini ribbon (chip blanco)"
    },
    {
      "type": "text",
      "id": "mini_ribbon_pre",
      "label": "Texto del chip",
      "default": "Disfruta tus días bajo el",
      "info": "Pequeño chip blanco encima del titular. Vacío = se oculta."
    },
    {
      "type": "text",
      "id": "mini_ribbon_script",
      "label": "Palabra final (script)",
      "default": "sol"
    },
    {
      "type": "header",
      "content": "Texto"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow (opcional)",
      "default": "The Colombian Tanning Ritual"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titular",
      "default": "Bronceado dorado, nacido en el Caribe"
    },
    {
      "type": "text",
      "id": "heading_gold_words",
      "label": "Palabras en script (separar por coma)",
      "default": "dorado,caribe",
      "info": "Las palabras del titular que aparecerán en tipografía manuscrita."
    },
    {
      "type": "textarea",
      "id": "lead",
      "label": "Párrafo lead",
      "default": "Aceites y bronceadores naturales formulados con zanahoria, coco y extractos del trópico colombiano."
    },
    {
      "type": "header",
      "content": "Social proof (rating)"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Mostrar rating con estrellas",
      "default": true,
      "info": "Aparece entre el lead y los botones. Aumenta la conversión con prueba social."
    },
    {
      "type": "text",
      "id": "rating_value",
      "label": "Valor del rating",
      "default": "4.9"
    },
    {
      "type": "text",
      "id": "rating_label",
      "label": "Etiqueta tras el rating",
      "default": "de 5"
    },
    {
      "type": "text",
      "id": "rating_count",
      "label": "Cantidad de reseñas",
      "default": "+1.842 reseñas"
    },
    {
      "type": "header",
      "content": "Botones"
    },
    {
      "type": "text",
      "id": "cta_primary_label",
      "label": "Botón principal",
      "default": "Comprar ritual"
    },
    {
      "type": "url",
      "id": "cta_primary_url",
      "label": "Destino botón principal"
    },
    {
      "type": "text",
      "id": "cta_secondary_label",
      "label": "Botón secundario"
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "Destino botón secundario"
    },
    {
      "type": "header",
      "content": "Fondo (imagen o video)"
    },
    {
      "type": "paragraph",
      "content": "Prioridad: video file → video URL → imagen. Si subes video, la imagen queda como fallback. Mute + loop + autoplay siempre."
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video de fondo (subido)",
      "info": "MP4 / MOV recomendado. Ideal: 2400 × 1200, 6-15 s, <8 MB."
    },
    {
      "type": "video_url",
      "id": "video_url",
      "label": "Video URL (YouTube / Vimeo)",
      "accept": ["youtube", "vimeo"],
      "info": "Alternativa al video subido. Se reproduce sin controles, en loop, mute."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen de fondo (fallback)",
      "info": "Aparece si no hay video. Recomendado: 2400 × 1200 px."
    },
    {
      "type": "range",
      "id": "overlay_strength",
      "label": "Intensidad del overlay rosado (%)",
      "min": 10, "max": 100, "step": 5, "unit": "%",
      "default": 65,
      "info": "10 = imagen casi sin tinte rosado · 100 = solo gradient rosado"
    },
    {
      "type": "header",
      "content": "Diseño"
    },
    {
