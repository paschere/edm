<script>
(function() {
  var THRESHOLD = 16000000;

  var lastShipDone = false;

  function updateDrawerShipBar(totalCents) {
    var bar = document.getElementById('edm-ship-bar-drawer');
    if (!bar) return;
    var remaining = THRESHOLD - totalCents;
    var pct = Math.min(100, Math.round((totalCents / THRESHOLD) * 100));
    var done = remaining <= 0;
    var fill = bar.querySelector('.edm-ship-bar__fill');
    var msg = bar.querySelector('.edm-ship-bar__msg');
    if (fill) fill.style.width = pct + '%';
    if (done) {
      bar.classList.add('edm-ship-bar--done');
      if (msg) {
        msg.innerHTML = '¡Desbloqueaste <strong>envío gratis</strong>! <span class="edm-script edm-ship-bar__msg-script">disfrútalo</span>';
        msg.classList.add('edm-ship-bar__msg--done');
      }
      if (!lastShipDone) fireConfetti();
      lastShipDone = true;
    } else {
      bar.classList.remove('edm-ship-bar--done');
      if (msg) {
        var formatted = '$ ' + Math.round(remaining / 100).toLocaleString('es-CO');
        msg.innerHTML = 'Te faltan <strong>' + formatted + '</strong> para <strong>envío gratis</strong>';
        msg.classList.remove('edm-ship-bar__msg--done');
      }
      lastShipDone = false;
    }
    var track = bar.querySelector('.edm-ship-bar__track');
    if (track) track.setAttribute('aria-valuenow', pct);
  }

  function fireConfetti() {
    var host = document.getElementById('edm-cart-confetti');
    if (!host) {
      host = document.createElement('div');
      host.id = 'edm-cart-confetti';
      host.className = 'edm-cart-confetti';
      document.body.appendChild(host);
    }
    host.innerHTML = '';
    var colors = ['#FF88BB', '#FF9966', '#FFCC99', '#FFA5D3', '#FFD9E4'];
    for (var i = 0; i < 36; i++) {
      var p = document.createElement('span');
      p.className = 'edm-cart-confetti__piece';
      p.style.left = (10 + Math.random() * 80) + '%';
      p.style.background = colors[i % colors.length];
      p.style.setProperty('--tx', ((Math.random() - 0.5) * 60) + 'vw');
      p.style.animationDelay = (Math.random() * 0.3) + 's';
      p.style.transform = 'rotate(' + (Math.random() * 360) + 'deg)';
      host.appendChild(p);
    }
    host.classList.add('is-active');
    setTimeout(function() { host.classList.remove('is-active'); host.innerHTML = ''; }, 2000);
  }

  if (typeof window.subscribe === 'function' && window.PUB_SUB_EVENTS) {
    window.subscribe(window.PUB_SUB_EVENTS.cartUpdate, function() {
      fetch('/cart.js').then(function(r) { return r.json(); }).then(function(cart) {
        updateDrawerShipBar(cart.total_price);
      });
    });
  }

  document.addEventListener('input', function(e) {
    if (e.target.id !== 'CartDrawer-cedula-input') return;
    var input = e.target;
    clearTimeout(input._edmTimer);
    var val = input.value;
    if (val.trim()) input.closest('.edm-cart-cedula').classList.remove('edm-cart-cedula--error');
    input._edmTimer = setTimeout(function() {
      fetch('/cart/update.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ attributes: { 'Cedula NIT': val } })
      });
    }, 600);
  });

  document.addEventListener('submit', function(e) {
    if (e.target.id !== 'CartDrawer-Form') return;
    if (!e.submitter || e.submitter.name !== 'checkout') return;
    var input = document.getElementById('CartDrawer-cedula-input');
    if (!input || input.value.trim() !== '') return;
    e.preventDefault();
    input.closest('.edm-cart-cedula').classList.add('edm-cart-cedula--error');
    input.focus();
  });

  document.addEventListener('edm:cart:opened', function(e) {
    var pid = e.detail && e.detail.productId;
    if (!pid) pid = sessionStorage.getItem('edm_last_pid');
    if (!pid) return;
    var el = document.getElementById('edm-upsell');
    if (!el) return;
    el.innerHTML = '';
    fetch('/recommendations/products.json?product_id=' + pid + '&limit=4')
      .then(function(r) { return r.ok ? r.json() : null; })
      .then(function(data) {
        if (!data || !data.products || !data.products.length) return;
        var prods = data.products;
        var html = '<p class="edm-upsell__title">También te puede gustar</p><div class="edm-upsell__list">';
        prods.forEach(function(p) {
          var img = p.images && p.images[0] ? p.images[0].src + '&width=240' : '';
          var price = '$ ' + Math.round(p.price / 100).toLocaleString('es-CO');
          html += '<a class="edm-upsell__card" href="/products/' + p.handle + '">';
          if (img) {
            html += '<img class="edm-upsell__img" src="' + img + '" alt="' + p.title.replace(/"/g, '&quot;') + '" loading="lazy" width="120" height="120">';
          }
          html += '<span class="edm-upsell__name">' + p.title + '</span>';
          html += '<span class="edm-upsell__price">' + price + '</span>';
          html += '</a>';
        });
        html += '</div>';
        el.innerHTML = html;
      })
      .catch(function() {});
  });
})();
</script>
