{% doc %}
Brand starfish icon (5-point plump shape with dotted center lines).
@param {string} [class] - CSS class to apply
@param {string} [stroke] - Color for the dotted center lines (default white)
@example
{% render 'edm-starfish', class: 'edm-hero__deco-star' %}
{% enddoc %}

<svg class="{{ class | default: 'edm-star' }}" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" fill="currentColor" aria-hidden="true">
  <path d="M50,6 C56,28 67,32 84,28 C75,42 78,52 92,60 C76,62 70,72 74,90 C60,80 50,80 36,92 C28,72 22,62 8,60 C22,52 24,42 16,28 C32,32 44,28 50,6 Z"/>
  <g stroke="{{ stroke | default: 'rgba(255,255,255,0.65)' }}" stroke-width="1.2" stroke-linecap="round" stroke-dasharray="1.5 3" fill="none">
    <line x1="50" y1="52" x2="50" y2="16"/>
    <line x1="50" y1="52" x2="78" y2="38"/>
    <line x1="50" y1="52" x2="74" y2="80"/>
    <line x1="50" y1="52" x2="32" y2="84"/>
    <line x1="50" y1="52" x2="20" y2="44"/>
  </g>
</svg>
