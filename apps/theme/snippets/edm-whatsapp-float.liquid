{% doc %}
Renders the global floating WhatsApp button.
Configured via theme settings: whatsapp_phone, whatsapp_message, whatsapp_product_message.
@example
{% render 'edm-whatsapp' %}
{% enddoc %}

{%- if settings.whatsapp_phone != blank -%}
  {%- if settings.whatsapp_product_message and request.page_type == 'product' and product.title != blank -%}
    {%- capture wa_text -%}Hola! Me interesa el producto: {{ product.title }}{%- endcapture -%}
  {%- else -%}
    {%- assign wa_text = settings.whatsapp_message -%}
  {%- endif -%}

  <a
    href="https://wa.me/{{ settings.whatsapp_phone }}?text={{ wa_text | url_encode }}"
    class="edm-wa"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Escríbenos por WhatsApp"
  >
    <svg class="edm-wa__icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
    <span class="edm-wa__tooltip">Escríbenos</span>
  </a>

  <style>
    .edm-wa {
      position: fixed;
      bottom: 2.4rem;
      right: 2.4rem;
      z-index: 490;
      width: 5.6rem;
      height: 5.6rem;
      border-radius: 50%;
      background: #25d366;
      color: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 4px 20px rgba(37,211,102,.45);
      text-decoration: none;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
      animation: edmWaPulse 3s ease-in-out 2s infinite;
    }
    .edm-wa:hover {
      transform: scale(1.08);
      box-shadow: 0 6px 28px rgba(37,211,102,.6);
      animation: none;
    }
    .edm-wa__icon {
      width: 3rem;
      height: 3rem;
    }
    .edm-wa__tooltip {
      position: absolute;
      right: calc(100% + 1.2rem);
      top: 50%;
      transform: translateY(-50%);
      background: #0b0805;
      color: #fbf8f1;
      font-size: 1.25rem;
      font-weight: 600;
      white-space: nowrap;
      padding: 0.6rem 1.2rem;
      border-radius: 100px;
      pointer-events: none;
      opacity: 0;
      transition: opacity 0.2s ease;
    }
    .edm-wa__tooltip::after {
      content: '';
      position: absolute;
      left: 100%;
      top: 50%;
      transform: translateY(-50%);
      border: 5px solid transparent;
      border-left-color: #0b0805;
    }
    .edm-wa:hover .edm-wa__tooltip { opacity: 1; }
    @keyframes edmWaPulse {
      0%, 100% { box-shadow: 0 4px 20px rgba(37,211,102,.45); }
      50% { box-shadow: 0 4px 32px rgba(37,211,102,.75), 0 0 0 8px rgba(37,211,102,.12); }
    }
    @media (max-width: 749px) {
      .edm-wa { width: 5rem; height: 5rem; bottom: 2rem; right: 1.6rem; }
      .edm-wa__icon { width: 2.6rem; height: 2.6rem; }
      .edm-wa__tooltip { display: none; }
    }
    .template-product .edm-wa {
      bottom: 9rem;
    }
    @media (min-width: 990px) {
      .template-product .edm-wa { bottom: 2.4rem; }
    }
  </style>
{%- endif -%}
